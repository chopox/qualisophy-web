const ctaButtons = [
  { label: "Contrata Talento Rural", href: "/contact?type=company-rural", variant: "solid" as const },
  { label: "Únete al Programa Talento Rural Tech", href: "/contact?type=candidate-rural", variant: "outline" as const }
