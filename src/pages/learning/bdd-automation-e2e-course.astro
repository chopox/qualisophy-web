---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Fundamentos de BDD",
    description:
      "Comprende los principios del Desarrollo Guiado por Comportamiento (BDD).",
    topics: [
      "Qué es BDD y sus beneficios",
      "Ciclo de vida del BDD",
      "Comunicación entre negocio y desarrollo",
      "Buenas prácticas de colaboración",
    ],
    icon: "BookOpen",
  },
  {
    id: "2",
    number: 2,
    title: "Sintaxis Gherkin y Cucumber",
    description:
      "Aprende a escribir escenarios de prueba con Cucumber y Gherkin.",
    topics: [
      "Estructura Given/When/Then",
      "Creación de Features y Steps",
      "Buenas prácticas en la redacción de escenarios",
      "Integración con repositorios de código",
    ],
    icon: "FileText",
  },
  {
    id: "3",
    number: 3,
    title: "Automatización E2E con Cypress",
    description: "Implementa pruebas de extremo a extremo con Cypress.",
    topics: [
      "Introducción a Cypress",
      "Configuración del entorno de pruebas",
      "Integración de Cucumber con Cypress",
      "Ejecución de escenarios automatizados",
    ],
    icon: "Zap",
  },
  {
    id: "4",
    number: 4,
    title: "Integración Continua y Pruebas Automatizadas",
    description: "Integra tus pruebas automatizadas en flujos CI/CD.",
    topics: [
      "Integración en pipelines de CI",
      "Gestión de reportes y métricas",
      "Buenas prácticas de automatización continua",
      "Monitoreo de pruebas automatizadas",
    ],
    icon: "Code",
  },
];

const instructor = {
  name: "Equipo QA",
  title: "Especialistas en BDD y Automatización",
  experience: "Experiencia en entornos Agile y CI/CD",
  description:
    "Curso impartido por profesionales con amplia experiencia en QA, automatización de pruebas y metodologías ágiles. Expertos en Cucumber, Gherkin y Cypress, con participación en proyectos reales de integración continua.",
  certifications: [
    "ISTQB Foundation Level",
    "Certificación en Cypress Automation",
    "Certificación en Continuous Integration (CI/CD)",
  ],
};

const courseDetails = {
  startDate: "10 de Marzo de 2025",
  duration: "30 horas (6 semanas)",
  schedule: "Martes y Jueves / 18:00 - 20:30",
  regularPrice: "420 €",
  earlyBirdPrice: "380 €",
};

const courseId = "individual-bdd";
const courseName = "Curso BDD y Automatización E2E";
---

<Layout title="Curso BDD y Automatización E2E - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
      <Breadcrumbs />
    </div>

    <Course
      client:load
      modules={modules}
      instructor={instructor}
      courseDetails={courseDetails}
      courseId={courseId}
    />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>
