---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Fundamentos de la Automatización",
    description: "Descubre qué es Power Automate y cómo puede ahorrarte horas de trabajo.",
    topics: [
      "Flujos de Nube vs Flujos de Escritorio (RPA)",
      "Desencadenadores (Triggers) y Acciones",
      "Uso de Plantillas vs Flujos desde cero",
      "Conectores Standard y Premium",
    ],
    icon: "Cloud",
  },
  {
    id: "2",
    number: 2,
    title: "Integración Microsoft 365",
    description: "Conecta Outlook, Teams, SharePoint y Forms automáticamente.",
    topics: [
      "Guardar adjuntos de correo en OneDrive/SharePoint",
      "Notificaciones automáticas en Teams",
      "Recolección de respuestas de Microsoft Forms",
      "Gestión de listas de SharePoint",
    ],
    icon: "Link",
  },
  {
    id: "3",
    number: 3,
    title: "Lógica de Control Avanzada",
    description: "Añade inteligencia a tus flujos con condiciones y bucles.",
    topics: [
      "Condiciones (If/Else) y Switch",
      "Bucles: Apply to each",
      "Variables, Expresiones y Fórmulas",
      "Manejo de errores y Timeouts",
    ],
    icon: "GitBranch",
  },
  {
    id: "4",
    number: 4,
    title: "Aprobaciones y Procesos de Negocio",
    description: "Digitaliza la burocracia interna con flujos de aprobación modernos.",
    topics: [
      "Creación de Aprobaciones (Approvals)",
      "Aprobaciones secuenciales y paralelas",
      "Integración de aprobaciones en Teams",
      "Gestión de rechazos y escalado",
    ],
    icon: "CheckCircle",
  },
];

const instructor = {
  name: "Cloud Architect",
  title: "Consultor de Productividad",
  description: "Especialista en Modern Workplace. Ayuda a las empresas a eliminar el trabajo manual y el papel mediante la suite Power Platform.",
  certifications: ["Power Platform App Maker Associate", "Microsoft 365 Certified"],
  experience: "7+ años de experiencia",
};

const courseDetails = {
  startDate: "A demanda (Online)",
  duration: "15 horas",
  schedule: "Flexible",
  regularPrice: "295 €",
  earlyBirdPrice: "250 €",
};

const courseId = "individual-power-automate";
const courseName = "Power Automate";
---

<Layout title="Curso Power Automate - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6"><Breadcrumbs /></div>
    <h1 class="text-center text-2xl md:text-3xl font-bold text-slate-800 mb-8 md:mb-16">
      Curso Power Automate
    </h1>
    <Course client:load modules={modules} instructor={instructor} courseDetails={courseDetails} courseId={courseId} />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>