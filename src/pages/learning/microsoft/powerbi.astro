---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Conexión y Transformación de Datos (ETL)",
    description: "Aprende a conectar Power BI a múltiples orígenes y a limpiar los datos con Power Query.",
    topics: [
      "Entorno de Power BI Desktop",
      "Conexión a Excel, SQL, Web y CSV",
      "Limpieza y transformación con Power Query",
      "Normalización de tablas y tipos de datos",
      "Carga de datos al modelo",
    ],
    icon: "Database",
  },
  {
    id: "2",
    number: 2,
    title: "Modelado de Datos",
    description: "Crea relaciones robustas entre tablas para permitir análisis complejos.",
    topics: [
      "Esquema de Estrella vs Copo de Nieve",
      "Relaciones (1:1, 1:N, N:N) y Cardinalidad",
      "Dirección del filtro cruzado",
      "Creación de Tablas Calendario",
      "Jerarquías y Categorización de datos",
    ],
    icon: "Layout",
  },
  {
    id: "3",
    number: 3,
    title: "Lenguaje DAX (Data Analysis Expressions)",
    description: "Domina el lenguaje de fórmulas de Power BI para crear medidas y cálculos de negocio.",
    topics: [
      "Columnas Calculadas vs Medidas",
      "Contexto de Fila vs Contexto de Filtro",
      "Funciones de Agregación e Iteradores (SUMX)",
      "La función CALCULATE y Time Intelligence",
      "Variables en DAX y optimización",
    ],
    icon: "Code",
  },
  {
    id: "4",
    number: 4,
    title: "Visualización y Storytelling",
    description: "Diseña informes interactivos que comuniquen insights de forma clara.",
    topics: [
      "Elección del gráfico adecuado",
      "Formato condicional y diseño corporativo",
      "Filtros, Segmentadores y Panel de Selección",
      "Marcadores (Bookmarks) y navegación",
      "Tooltips personalizados y Drill-through",
    ],
    icon: "PieChart",
  },
];

const instructor = {
  name: "Consultor BI Senior",
  title: "Microsoft Data Analyst Associate",
  description: "Consultor experto en Business Intelligence con más de 8 años implementando soluciones de Power Platform en empresas del IBEX 35.",
  certifications: ["Microsoft Certified: Data Analyst Associate", "MCT (Microsoft Certified Trainer)"],
  experience: "8+ años de experiencia",
};

const courseDetails = {
  startDate: "10 de Marzo de 2025",
  duration: "30 horas (6 semanas)",
  schedule: "Martes y Jueves / 18:30 - 21:00",
  regularPrice: "450 €",
  earlyBirdPrice: "395 €",
};

const courseId = "individual-powerbi";
const courseName = "Power BI Dashboards";
---

<Layout title="Curso Power BI Dashboards - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6"><Breadcrumbs /></div>
    <h1 class="text-center text-2xl md:text-3xl font-bold text-slate-800 mb-8 md:mb-16">
      Curso Power BI Dashboards
    </h1>
    <Course client:load modules={modules} instructor={instructor} courseDetails={courseDetails} courseId={courseId} />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>