---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Introducción a TQM y Cultura de Calidad",
    description:
      "Comprende los pilares de la Gestión de Calidad Total (TQM) y cómo instaurar una cultura de mejora continua en la organización.",
    topics: [
      "Principios fundamentales del TQM",
      "Diferencia entre QA, QC y QM",
      "Coste de la Calidad (CoQ)",
      "El ciclo PDCA (Plan-Do-Check-Act)",
    ],
    icon: "BookOpen",
  },
  {
    id: "2",
    number: 2,
    title: "Estrategia y Planificación de Pruebas",
    description:
      "Aprende a diseñar estrategias de prueba alineadas con los objetivos de negocio y a gestionar riesgos.",
    topics: [
      "Elaboración del Plan de Pruebas Maestro (Master Test Plan)",
      "Gestión de Riesgos en QA",
      "Definición de alcance y criterios de salida",
      "Estimación de esfuerzos de testing",
    ],
    icon: "Map",
  },
  {
    id: "3",
    number: 3,
    title: "Métricas, KPIs y Reporting",
    description:
      "Define y analiza las métricas clave para medir la salud del proyecto y la eficiencia del equipo de QA.",
    topics: [
      "Definición de KPIs relevantes (Defect Density, Leakage)",
      "Métricas de cobertura y ejecución",
      "Creación de Dashboards de Calidad efectivos",
      "Comunicación de resultados a stakeholders",
    ],
    icon: "BarChart",
  },
  {
    id: "4",
    number: 4,
    title: "Liderazgo de Equipos de QA",
    description:
      "Desarrolla habilidades para gestionar equipos de testing, resolver conflictos y fomentar el crecimiento profesional.",
    topics: [
      "Roles y responsabilidades en el equipo QA",
      "Mentoring y planes de carrera para testers",
      "Gestión de equipos distribuidos y offshore",
      "Evaluación del desempeño y feedback",
    ],
    icon: "Users",
  },
];

const instructor = {
  name: "Director de QA",
  title: "Experto en Gestión de Calidad",
  experience: "15+ años liderando departamentos de QA",
  description:
    "Consultor senior especializado en la implementación de oficinas de calidad (TMO) y mejora de procesos. Ha liderado transformaciones de calidad en grandes corporaciones bancarias y de telecomunicaciones.",
  certifications: [
    "ISTQB Expert Level Test Management",
    "PMP (Project Management Professional)",
    "Lean Six Sigma Black Belt",
  ],
};

const courseDetails = {
  startDate: "24 de Marzo de 2025",
  duration: "25 horas (5 semanas)",
  schedule: "Lunes y Miércoles / 19:00 - 21:30",
  regularPrice: "450 €",
  earlyBirdPrice: "395 €",
};

const courseId = "individual-tqm";
const courseName = "Gestión de Calidad (TQM)";
---

<Layout title="Curso Gestión de Calidad (TQM) - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
      <Breadcrumbs />
    </div>

    <h1
      class="text-center text-2xl md:text-3xl font-bold text-slate-800 mb-8 md:mb-16"
    >
      Gestión de Calidad (TQM)
    </h1>

    <Course
      client:load
      modules={modules}
      instructor={instructor}
      courseDetails={courseDetails}
      courseId={courseId}
    />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>