---
import Layout from "@/layouts/Layout.astro";
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { CourseGridCard } from "@/components/react/course/CourseGridCard";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

// Importación de imágenes locales
import imgQa from "@/assets/imagenes-cursos/qa/qa-curso.png";
import imgCypress from "@/assets/imagenes-cursos/qa/cypress-bootcamp.png";

// Datos enriquecidos para la UI
const courses = [
  {
    title: "Testing y Calidad del Software",
    description: "Domina los fundamentos del testing manual, diseño de casos de prueba, reporte de bugs y metodologías ágiles como Scrum aplicadas a QA.",
    imageUrl: imgQa.src, // Imagen local
    href: "/learning/qa/software-quality-testing-course",
    level: "Principiante",
    duration: "40 Horas",
    modality: "Online",
    category: "QA Manual"
  },
  {
    title: "Cypress Bootcamp: Automatización E2E con BDD",
    description: "Aprende a automatizar pruebas funcionales utilizando Cucumber, Gherkin y Cypress. Integra tus pruebas en entornos de integración continua.",
    imageUrl: imgCypress.src, // Imagen local
    href: "/learning/qa/cypress-bootcamp",
    level: "Intermedio",
    duration: "36 Horas",
    modality: "Online",
    category: "Automation"
  },
  {
    title: "Coding & DevOps for Testers",
    description: "Da el salto técnico: aprende JavaScript, Git, Docker y creación de Pipelines de CI/CD orientados específicamente al testing automatizado.",
    imageUrl: "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&q=80",
    href: "/learning/qa/devops-for-testers-course",
    level: "Avanzado",
    duration: "48 Horas",
    modality: "Online",
    category: "DevOps"
  },
  {
    title: "Gestión de Calidad (TQM)",
    description: "Estrategias de gestión total de la calidad, definición de métricas, KPIs, liderazgo de equipos de QA y mejora de procesos.",
    imageUrl: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80",
    href: "/corporate-training/qa/quality-management",
    level: "Avanzado",
    duration: "25 Horas",
    modality: "Híbrido",
    category: "Management"
  }
];
---

<Layout 
  title="Cursos de QA y Testing - Qualisophy" 
  fullWidth={true}
>
  
  {/* Hero Banner ocupando todo el ancho */}
  <ProgramHero
    client:load
    title="Escuela de"
    highlight="QA & Testing"
    subtitle="Formación especializada para asegurar la calidad del software. Desde fundamentos manuales hasta automatización avanzada y DevOps."
    backgroundImage="https://images.unsplash.com/photo-1580894732444-8ecded7900cd?auto=format&fit=crop&q=80"
    ctaText="Ver Itinerarios"
    onCtaClick={() => document.getElementById('courses-grid')?.scrollIntoView({ behavior: 'smooth' })}
  />

  <div class="bg-gray-50/50 min-h-screen">
    {/* Breadcrumbs con contenedor propio para márgenes correctos */}
    <div class="container mx-auto px-6 pt-8 pb-4">
        <Breadcrumbs />
    </div>

    {/* Sección de Cursos */}
    <section id="courses-grid" class="py-12 pb-24">
        <div class="container mx-auto px-6">
        
        {/* Encabezado de Sección */}
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4 border-b border-gray-200 pb-6">
            <div class="max-w-2xl">
                <h2 class="text-3xl font-bold font-heading text-secondary mb-2">Itinerarios de Especialización</h2>
                <p class="text-gray-600 font-primary">
                    Explora nuestros programas diseñados para cubrir las necesidades actuales del mercado tecnológico en QA.
                </p>
            </div>
            <div class="hidden md:block text-sm text-gray-400 font-medium">
                Mostrando {courses.length} cursos
            </div>
        </div>

        {/* Grid de Tarjetas */}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            {courses.map((course) => (
            <CourseGridCard
                client:visible
                title={course.title}
                description={course.description}
                imageSrc={course.imageUrl}
                href={course.href}
                level={course.level as "Principiante" | "Intermedio" | "Avanzado"}
                duration={course.duration}
                modality={course.modality as "Online" | "Presencial" | "Híbrido"}
                category={course.category}
            />
            ))}
        </div>
        </div>
    </section>
  </div>
</Layout>