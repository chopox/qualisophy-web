---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Liderazgo en la Era Digital",
    description: "Evolucionando del 'Jefe' al 'Líder Servicial'.",
    topics: [
      "Servant Leadership y Management 3.0",
      "Inteligencia Emocional en el liderazgo",
      "Estilos de liderazgo situacional",
      "Construcción de confianza y seguridad psicológica",
    ],
    icon: "User",
  },
  {
    id: "2",
    number: 2,
    title: "Gestión de Equipos de Alto Rendimiento",
    description: "Creando el entorno para que el equipo brille.",
    topics: [
      "Fases de desarrollo de equipo (Tuckman)",
      "Motivación intrínseca (Autonomía, Maestría, Propósito)",
      "Delegación efectiva y empoderamiento",
      "Gestión de la diversidad",
    ],
    icon: "Users",
  },
  {
    id: "3",
    number: 3,
    title: "Comunicación y Feedback",
    description: "Herramientas para conversaciones difíciles y crecimiento.",
    topics: [
      "Escucha activa y empatía",
      "Modelos de Feedback constructivo (SBI, CNV)",
      "Reuniones 1:1 efectivas",
      "Gestión de conflictos",
    ],
    icon: "MessageCircle",
  },
  {
    id: "4",
    number: 4,
    title: "Desarrollo de Talento",
    description: "Haciendo crecer a las personas.",
    topics: [
      "Coaching vs Mentoring",
      "Planes de carrera y evaluación del desempeño",
      "Contratación y Onboarding",
      "Cultura de aprendizaje continuo",
    ],
    icon: "TrendingUp",
  },
];

const instructor = {
  name: "Executive Coach",
  title: "Experto en Liderazgo Técnico",
  description: "Coach ejecutivo especializado en ayudar a ingenieros y managers a desarrollar sus soft skills.",
  certifications: ["Certified Executive Coach", "Management 3.0 Facilitator"],
  experience: "15+ años de experiencia",
};

const courseDetails = {
  startDate: "A demanda",
  duration: "20 horas",
  schedule: "Flexible",
  regularPrice: "450 €",
  earlyBirdPrice: "395 €",
};

const courseId = "individual-leadership";
const courseName = "Liderazgo de Equipos";
---

<Layout title="Curso Liderazgo de Equipos - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6"><Breadcrumbs /></div>
    <h1 class="text-center text-2xl md:text-3xl font-bold text-slate-800 mb-8 md:mb-16">
      Liderazgo de Equipos
    </h1>
    <Course client:load modules={modules} instructor={instructor} courseDetails={courseDetails} courseId={courseId} />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>