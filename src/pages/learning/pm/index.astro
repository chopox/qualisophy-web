---
import Layout from "@/layouts/Layout.astro";
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { CourseGridCard } from "@/components/react/course/CourseGridCard";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const courses = [
  {
    title: "Certificación Scrum Master",
    description: "Lidera equipos ágiles. Aprende los eventos, artefactos y roles de Scrum para gestionar proyectos complejos.",
    imageUrl: "https://images.unsplash.com/photo-1531498860503-6c0a1b71285f?auto=format&fit=crop&q=80",
    href: "/learning/pm/scrum-master",
    level: "Intermedio",
    duration: "20 Horas",
    modality: "Online",
    category: "Agile"
  },
  {
    title: "Product Owner",
    description: "Maximiza el valor del producto. Aprende a gestionar el Backlog, definir historias de usuario y priorizar.",
    imageUrl: "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80",
    href: "/learning/pm/product-owner",
    level: "Avanzado",
    duration: "25 Horas",
    modality: "Online",
    category: "Product"
  },
  {
    title: "Gestión Ágil con Kanban",
    description: "Mejora el flujo de trabajo. Visualiza tareas, limita el trabajo en curso y optimiza la entrega continua.",
    imageUrl: "https://images.unsplash.com/photo-1507537297725-24a1c434c67b?auto=format&fit=crop&q=80",
    href: "/learning/pm/kanban",
    level: "Principiante",
    duration: "15 Horas",
    modality: "Online",
    category: "Agile"
  },
  {
    title: "Liderazgo de Equipos Técnicos",
    description: "Habilidades blandas para líderes. Comunicación efectiva, resolución de conflictos y motivación de equipos.",
    imageUrl: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&q=80",
    href: "/learning/pm/leadership",
    level: "Avanzado",
    duration: "30 Horas",
    modality: "Presencial",
    category: "Soft Skills"
  }
];
---

<Layout title="Cursos de Project Management - Qualisophy" fullWidth={true}>
  <ProgramHero
    client:load
    title="Escuela de"
    highlight="Management"
    subtitle="Lidera el cambio. Metodologías ágiles y habilidades directivas para gestionar proyectos y equipos de alto rendimiento."
    backgroundImage="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80"
    ctaText="Ver Programas de Gestión"
    onCtaClick={() => document.getElementById('courses-grid')?.scrollIntoView({ behavior: 'smooth' })}
  />

  <div class="bg-gray-50/50 min-h-screen">
    <div class="container mx-auto px-6 pt-8 pb-4">
        <Breadcrumbs />
    </div>

    <section id="courses-grid" class="py-12 pb-24">
        <div class="container mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4 border-b border-gray-200 pb-6">
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-bold font-heading text-secondary mb-2">Liderazgo y Agilidad</h2>
                    <p class="text-gray-600 font-primary">Adquiere las competencias necesarias para dirigir proyectos en entornos modernos.</p>
                </div>
                <div class="hidden md:block text-sm text-gray-400 font-medium">Mostrando {courses.length} cursos</div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                {courses.map((course) => (
                <CourseGridCard
                    client:visible
                    title={course.title}
                    description={course.description}
                    imageSrc={course.imageUrl}
                    href={course.href}
                    level={course.level as "Principiante" | "Intermedio" | "Avanzado"}
                    duration={course.duration}
                    modality={course.modality as "Online" | "Presencial" | "Híbrido"}
                    category={course.category}
                />
                ))}
            </div>
        </div>
    </section>
  </div>
</Layout>