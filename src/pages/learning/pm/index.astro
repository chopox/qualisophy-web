---
import Layout from "@/layouts/Layout.astro";
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { ContentCard } from "@/components/react/shared/ContentCard";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const courses = [
  {
    title: "Certificación Scrum Master",
    description: "Lidera equipos ágiles. Aprende los eventos, artefactos y roles de Scrum para gestionar proyectos complejos.",
    imageUrl: "https://images.unsplash.com/photo-1531498860503-6c0a1b71285f?auto=format&fit=crop&q=80",
    href: "/learning/pm/scrum-master",
  },
  {
    title: "Product Owner",
    description: "Maximiza el valor del producto. Aprende a gestionar el Backlog, definir historias de usuario y priorizar.",
    imageUrl: "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80",
    href: "/learning/pm/product-owner",
  },
  {
    title: "Gestión Ágil con Kanban",
    description: "Mejora el flujo de trabajo. Visualiza tareas, limita el trabajo en curso y optimiza la entrega continua.",
    imageUrl: "https://images.unsplash.com/photo-1507537297725-24a1c434c67b?auto=format&fit=crop&q=80",
    href: "/learning/pm/kanban",
  },
  {
    title: "Liderazgo de Equipos Técnicos",
    description: "Habilidades blandas para líderes. Comunicación efectiva, resolución de conflictos y motivación de equipos.",
    imageUrl: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&q=80",
    href: "/learning/pm/leadership",
  }
];
---

<Layout title="Cursos de Project Management - Qualisophy">
  <ProgramHero
    client:load
    title="Escuela de"
    highlight="Management"
    subtitle="Lidera el cambio. Metodologías ágiles y habilidades directivas para gestionar proyectos y equipos de alto rendimiento."
    backgroundImage="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80"
    ctaText="Ver Programas de Gestión"
    onCtaClick={() => document.getElementById('courses')?.scrollIntoView({ behavior: 'smooth' })}
  />

  <div class="container mx-auto px-6 py-8">
    <Breadcrumbs />
  </div>

  <section id="courses" class="py-12 pb-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl font-bold font-heading text-secondary mb-4">Liderazgo y Agilidad</h2>
        <p class="text-gray-600 font-primary">Adquiere las competencias necesarias para dirigir proyectos en entornos modernos.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {courses.map((course) => (
          <ContentCard
            title={course.title}
            description={course.description}
            imageUrl={course.imageUrl}
            buttonText="Ver Programa"
            buttonHref={course.href}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>