---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Fundamentos de Kanban",
    description: "Entendiendo el flujo y la filosofía Lean.",
    topics: [
      "Orígenes y Principios de Kanban",
      "Visualización del trabajo",
      "Sistema Pull vs Push",
      "Diferencias con Scrum",
    ],
    icon: "Layout",
  },
  {
    id: "2",
    number: 2,
    title: "Diseño de Sistemas Kanban",
    description: "Creando tableros que reflejen la realidad.",
    topics: [
      "Mapeo del flujo de valor (Value Stream)",
      "Diseño de tableros y tarjetas",
      "Políticas explícitas",
      "Clases de Servicio (CoS)",
    ],
    icon: "Trello",
  },
  {
    id: "3",
    number: 3,
    title: "Gestión del Flujo (WIP)",
    description: "La clave de la eficiencia: Limitar el trabajo en curso.",
    topics: [
      "Límites WIP (Work In Progress)",
      "Ley de Little",
      "Gestión de cuellos de botella y bloqueos",
      "Multitasking y coste de contexto",
    ],
    icon: "Filter",
  },
  {
    id: "4",
    number: 4,
    title: "Métricas y Mejora Continua",
    description: "Datos para predecir y mejorar (Kaizen).",
    topics: [
      "Lead Time y Cycle Time",
      "Diagrama de Flujo Acumulativo (CFD)",
      "Throughput y Previsibilidad",
      "Reuniones de revisión y mejora",
    ],
    icon: "Activity",
  },
];

const instructor = {
  name: "Kanban Trainer",
  title: "Accredited Kanban Professional",
  description: "Consultor experto en eficiencia operativa y mejora de procesos mediante método Kanban.",
  certifications: ["Kanban Management Professional (KMP)", "Lean Six Sigma"],
  experience: "9+ años de experiencia",
};

const courseDetails = {
  startDate: "A demanda (Online)",
  duration: "12 horas",
  schedule: "Flexible",
  regularPrice: "295 €",
  earlyBirdPrice: "250 €",
};

const courseId = "individual-kanban";
const courseName = "Gestión Ágil (Kanban)";
---

<Layout title="Curso Gestión Ágil (Kanban) - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6"><Breadcrumbs /></div>
    <h1 class="text-center text-2xl md:text-3xl font-bold text-slate-800 mb-8 md:mb-16">
      Gestión Ágil (Kanban)
    </h1>
    <Course client:load modules={modules} instructor={instructor} courseDetails={courseDetails} courseId={courseId} />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>