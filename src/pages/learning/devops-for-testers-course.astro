---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Fundamentos de Programación para Testers",
    description:
      "Aprende los fundamentos de JavaScript y desarrollo para automatizar de forma eficaz.",
    topics: [
      "Conceptos básicos de programación",
      "Estructuras de control y funciones",
      "Manipulación del DOM con JavaScript",
      "Buenas prácticas de codificación para testers",
    ],
    icon: "Code",
  },
  {
    id: "2",
    number: 2,
    title: "Automatización con Herramientas Modernas",
    description:
      "Aprende a utilizar herramientas de automatización ampliamente usadas.",
    topics: [
      "Introducción a Cypress y Playwright",
      "Testing de APIs con Postman",
      "Creación de suites de pruebas automatizadas",
      "Gestión de dependencias y entorno de pruebas",
    ],
    icon: "Zap",
  },
  {
    id: "3",
    number: 3,
    title: "Introducción a Git y Control de Versiones",
    description: "Gestiona y colabora en proyectos con Git y GitHub.",
    topics: [
      "Fundamentos de Git y ramas",
      "Comandos esenciales",
      "Pull Requests y revisiones de código",
      "Buenas prácticas en control de versiones",
    ],
    icon: "GitBranch",
  },
  {
    id: "4",
    number: 4,
    title: "Integración Continua con GitLab CI/CD",
    description: "Configura pipelines automáticos de testing y despliegue.",
    topics: [
      "Conceptos de CI/CD",
      "Configuración básica en GitLab",
      "Ejecución automática de pruebas",
      "Optimización y reportes de pipelines",
    ],
    icon: "Server",
  },
];

const instructor = {
  name: "Laura Sánchez",
  title: "Ingeniera de Software y DevOps",
  description:
    "Laura Sánchez cuenta con más de 10 años de experiencia en desarrollo y entornos CI/CD. Certificada en AWS y GitLab CI/CD.",
  certifications: ["AWS Certified", "GitLab CI/CD Professional"],
  experience: "10+ años de experiencia",
};

const courseDetails = {
  startDate: "3 de Marzo de 2025",
  duration: "48 horas (8 semanas)",
  schedule: "Martes y Jueves, 18:00 - 21:00",
  regularPrice: "540 €",
  earlyBirdPrice: "490 €",
};

const courseId = "individual-devops";
const courseName = "Coding and DevOps for Testers";
---

<Layout title="Coding and DevOps for Testers - Qualisophy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
      <Breadcrumbs />
    </div>

    <Course
      client:load
      modules={modules}
      instructor={instructor}
      courseDetails={courseDetails}
      courseId={courseId}
    />
    <EnrollButton client:load courseId={courseId} courseName={courseName} />
  </div>
</Layout>
