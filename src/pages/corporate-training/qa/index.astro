---
import Layout from "@/layouts/Layout.astro";
import { CourseGridCard } from "@/components/react/course/CourseGridCard";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const courses = [
  {
    title: "Testing Manual & QA",
    description: "Estandarización de procesos de testing. Diseño de planes de prueba, casos de uso y reporte de incidencias en Jira/Azure DevOps.",
    imageUrl: "https://images.unsplash.com/photo-1516116216624-53e697fedbea?auto=format&fit=crop&q=80",
    href: "/corporate-training/qa/manual-testing",
    level: "Principiante",
    duration: "20h - Intensivo",
    modality: "In-Company",
    category: "QA Manual"
  },
  {
    title: "Automatización con Cypress",
    description: "Creación de frameworks de automatización modernos. Pruebas E2E robustas, integración continua y reporting automático.",
    imageUrl: "https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?auto=format&fit=crop&q=80",
    href: "/corporate-training/qa/automation-course",
    level: "Intermedio",
    duration: "30h - Práctico",
    modality: "Híbrido",
    category: "Automation"
  },
  {
    title: "DevOps for Testers",
    description: "El tester en el ciclo DevOps. Docker, Pipelines de CI/CD (Jenkins/GitLab), y estrategias de Continuous Testing.",
    imageUrl: "https://images.unsplash.com/photo-1667372393119-c81c0cda71cd?auto=format&fit=crop&q=80",
    href: "/corporate-training/qa/devops",
    level: "Avanzado",
    duration: "25h - Workshop",
    modality: "Online",
    category: "DevOps"
  },
  {
    title: "Gestión de Calidad (TQM)",
    description: "Estrategia de QA para managers. Definición de KPIs, gestión de equipos de testing y mejora de procesos de calidad.",
    imageUrl: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80",
    href: "/corporate-training/qa/quality-management",
    level: "Avanzado",
    duration: "15h - Seminario",
    modality: "Presencial",
    category: "Management"
  }
];
---

<Layout title="Testing y QA - Formación para Empresas | Qualisophy" fullWidth={true}>
  
  {/* SECCIÓN CABECERA */}
  <section class="pt-6 pb-12 bg-white border-b border-gray-100">
    <div class="container mx-auto px-6">
      <div class="mb-8">
        <Breadcrumbs />
      </div>

      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl font-bold font-heading text-slate-800 mb-4">
          Formación en Testing y QA
        </h1>
        <p class="text-slate-600 text-lg">
          Capacita a tus equipos en aseguramiento de calidad. Desde fundamentos de testing manual hasta automatización avanzada y DevOps.
        </p>
      </div>
    </div>
  </section>

  {/* SECCIÓN GRID */}
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {courses.map((course) => (
          <CourseGridCard
            client:visible
            title={course.title}
            description={course.description}
            imageSrc={course.imageUrl}
            href={course.href}
            level={course.level as "Principiante" | "Intermedio" | "Avanzado"}
            duration={course.duration}
            modality={course.modality as "Online" | "Presencial" | "Híbrido"}
            category={course.category}
          />
        ))}
      </div>
    </div>
  </section>

</Layout>