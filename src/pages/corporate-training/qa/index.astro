---
import Layout from "@/layouts/Layout.astro";
import QACoursesList from "@/components/react/course/QACoursesList";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
---

<Layout title="Testing y QA - Formación para Empresas | Qualisophy">
  <section class="pt-6 pb-12 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-8">
        <Breadcrumbs />
      </div>

      <div class="text-center">
        <h1 class="text-4xl font-bold text-slate-800 mb-4">
          Formación en Testing y QA
        </h1>
        <p class="text-slate-600 max-w-2xl mx-auto mb-12">
          Capacita a tus equipos en testing manual, automatización y gestión de
          calidad del software. Mejora la eficiencia y fiabilidad en cada
          entrega.
        </p>
      </div>
    </div>

    <QACoursesList client:load />
  </section>
</Layout>
