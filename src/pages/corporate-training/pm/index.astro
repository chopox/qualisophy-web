---
import Layout from "@/layouts/Layout.astro";
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { CourseGridCard } from "@/components/react/course/CourseGridCard";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

const courses = [
  {
    title: "Certificación Scrum Master",
    description: "Formación práctica para facilitar eventos Scrum, eliminar impedimentos y guiar al equipo hacia la autogestión y el alto rendimiento.",
    imageUrl: "https://images.unsplash.com/photo-1531498860503-6c0a1b71285f?auto=format&fit=crop&q=80",
    href: "/corporate-training/pm/scrum",
    level: "Intermedio",
    duration: "16h - Workshop",
    modality: "Presencial / Online",
    category: "Agile Frameworks"
  },
  {
    title: "Product Owner & Gestión del Valor",
    description: "Maximiza el ROI del producto. Técnicas avanzadas para gestión del Backlog, priorización por valor, historias de usuario y gestión de stakeholders.",
    imageUrl: "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80",
    href: "/corporate-training/pm/product-owner",
    level: "Avanzado",
    duration: "20h - Intensivo",
    modality: "Híbrido",
    category: "Product Management"
  },
  {
    title: "Gestión Ágil con Kanban",
    description: "Mejora el flujo de trabajo continuo. Visualización, limitación del WIP (trabajo en curso) y métricas de flujo para equipos de servicios y soporte.",
    imageUrl: "https://images.unsplash.com/photo-1507537297725-24a1c434c67b?auto=format&fit=crop&q=80",
    href: "/corporate-training/pm/kanban",
    level: "Principiante",
    duration: "12h - Taller",
    modality: "Online",
    category: "Lean / Agile"
  },
  {
    title: "Liderazgo de Equipos Técnicos",
    description: "Soft skills para Tech Leads y Managers. Comunicación efectiva, resolución de conflictos, motivación 3.0 y liderazgo servicial.",
    imageUrl: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&q=80",
    href: "/corporate-training/pm/leadership",
    level: "Avanzado",
    duration: "24h - Executive",
    modality: "Presencial",
    category: "Soft Skills"
  }
];
---

<Layout title="Formación en Project Management para Empresas - Qualisophy" fullWidth={true}>
  
  <ProgramHero
    client:load
    title="Formación Corporativa en"
    highlight="Project Management"
    subtitle="Metodologías ágiles y habilidades directivas para transformar la forma en que tus equipos entregan valor."
    backgroundImage="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80"
    ctaText="Consultar disponibilidad"
    onCtaClick={() => window.location.href = '/contact'}
  />

  <div class="bg-gray-50/50 min-h-screen">
    <div class="container mx-auto px-6 pt-8 pb-4">
        <Breadcrumbs />
    </div>

    <section id="courses-grid" class="py-12 pb-24">
        <div class="container mx-auto px-6">
        
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4 border-b border-gray-200 pb-6">
            <div class="max-w-2xl">
                <h2 class="text-3xl font-bold font-heading text-secondary mb-2">Liderazgo y Agilidad Organizacional</h2>
                <p class="text-gray-600 font-primary">
                    Capacita a tus líderes y equipos en los marcos de trabajo más eficientes del mercado actual.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            {courses.map((course) => (
            <CourseGridCard
                client:visible
                title={course.title}
                description={course.description}
                imageSrc={course.imageUrl}
                href={course.href}
                level={course.level as "Principiante" | "Intermedio" | "Avanzado"}
                duration={course.duration}
                modality={course.modality as "Online" | "Presencial" | "Híbrido"}
                category={course.category}
            />
            ))}
        </div>
        </div>
    </section>
  </div>
</Layout>