---
import Layout from "@/layouts/Layout.astro";
import DevCoursesList from "@/components/react/course/DevCoursesList";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
---

<Layout title="Desarrollo Web - Formación para Empresas | Qualisophy">
  <section class="pt-6 pb-12 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-8">
        <Breadcrumbs />
      </div>

      <div class="text-center">
        <h1 class="text-4xl font-bold text-slate-800 mb-4">
          Formación en Desarrollo Web
        </h1>
        <p class="text-slate-600 max-w-2xl mx-auto mb-12">
          Mejora las capacidades de tu equipo con programas de formación en
          frontend, backend y desarrollo full stack. Cursos diseñados para
          proyectos reales y metodologías ágiles.
        </p>
      </div>
    </div>

    <DevCoursesList client:load />
  </section>
</Layout>
