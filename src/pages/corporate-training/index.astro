---
import Layout from "@/layouts/Layout.astro";
import { CorporateAreasList } from "@/components/react/corporate-training/CorporateAreasList";
import { CorporateTrainingHero } from "@/components/react/corporate-training/CorporateTrainingHero";
import { CustomTrainingProgram } from "@/components/react/corporate-training/CustomTrainingProgram";
import { CompanyCarousel } from "@/components/react/corporate-training/CompanyCarousel";
// Eliminamos ContactForm
// Importamos el CTA estandarizado
import { ProgramCTA } from "@/components/react/programs/ProgramCTA";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

// --- DATOS DEL CTA (Enfoque Empresas) ---
const ctaButtons = [
  { label: "Solicitar Propuesta", href: "/contact?type=company", variant: "solid" as const },
  { label: "Agendar Reunión", href: "/contact", variant: "outline" as const }
];
---

<Layout title="Formación para Empresas - Qualisophy" fullWidth={true}>
  
  {/* 1. HERO SECTION */}
  <CorporateTrainingHero client:load />

  {/* 2. BREADCRUMBS (Contenedor limitado) */}
  <div class="container mx-auto px-6 pt-8">
    <Breadcrumbs />
  </div>

  {/* 3. CATÁLOGO DE ÁREAS (Identificador para el scroll) */}
  <div id="corporate-areas">
    <CorporateAreasList client:load />
  </div>

  {/* 4. METODOLOGÍA Y BENEFICIOS */}
  <CustomTrainingProgram client:load />

  {/* 5. PRUEBA SOCIAL (LOGOS) */}
  <div class="py-12">
      <CompanyCarousel client:load />
  </div>

  {/* 6. CTA FINAL (Sustituye al Formulario) */}
  {/* Usamos variant="blue" para que tenga fondo GRIS CLARO y contraste con el carrusel blanco */}
  <div id="program-cta">
    <ProgramCTA 
      client:visible 
      title="Diseñamos el plan perfecto para tu equipo"
      description="Cuéntanos tus objetivos. Creamos planes a medida, bonificables por FUNDAE y con instructores senior en activo."
      buttons={ctaButtons}
      variant="blue" 
    />
  </div>

</Layout>