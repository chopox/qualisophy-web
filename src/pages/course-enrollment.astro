  // (Se mantienen los de empresas por si se usan en B2B)
  "enterprise-frontend": { id: "enterprise-frontend", name: "Curso Frontend Moderno", description: "Domina React, Vue y las últimas tecnologías frontend.", image: "https://images.unsplash.com/photo-1610563166150-b34df4f3bcd6?auto=format&fit=crop&w=1470&q=80", startDate: "A consultar", duration: "Personalizable", modality: "Online / Presencial", price: "447 €" },
  "enterprise-backend": { id: "enterprise-backend", name: "Curso Backend Escalable", description: "Aprende a construir APIs robustas y escalables.", image: "https://images.unsplash.com/photo-1559526324-593bc073d938?auto=format&fit=crop&w=1470&q=80", startDate: "A consultar", duration: "Personalizable", modality: "Online / Presencial", price: "525 €" },
