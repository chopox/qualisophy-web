  "enterprise-quality": { id: "enterprise-quality", name: "Gestión de Calidad del Software", description: "Gestiona la calidad en proyectos empresariales.", image: "https://images.unsplash.com/photo-1555949963-aa79dcee981c?auto=format&fit=crop&w=1470&q=80", startDate: "A consultar", duration: "Personalizable", modality: "Online / Presencial", price: "497 €" },
  "enterprise-dashboards": { id: "enterprise-dashboards", name: "Dashboards y Visualización", description: "Crea dashboards impactantes con Power BI.", image: "https://images.unsplash.com/photo-1526628953301-3e589a6a8b74?auto=format&fit=crop&w=1470&q=80", startDate: "A consultar", duration: "Personalizable", modality: "Online / Presencial", price: "497 €" },
  "enterprise-analytics": { id: "enterprise-analytics", name: "Data Analytics Fundamentals", description: "Fundamentos de análisis de datos empresariales.", image: "https://images.unsplash.com/photo-1640158615573-cd28feb1bf4e?auto=format&fit=crop&w=1470&q=80", startDate: "A consultar", duration: "Personalizable", modality: "Online / Presencial", price: "450 €" },
};

// Get selected course or null
const selectedCourse = courseId && courseCatalog[courseId] ? courseCatalog[courseId] : null;

// Prepare course list for dropdown
const courses = Object.values(courseCatalog).map((course) => ({
  id: course.id,
  name: course.name,
}));

// Formateamos la categoría para los breadcrumbs ("qa" -> "QA & Testing")
const formatCategoryName = (slug: string) => {
  if (slug === 'qa') return 'QA & Testing';
  if (slug === 'dev') return 'Desarrollo';
  if (slug === 'pm') return 'Project Management';
  if (slug === 'microsoft') return 'Microsoft & Data';
  return 'Formación';
};

// Course card data (only if course is selected)
const courseCardData = selectedCourse
  ? {
      title: selectedCourse.name,
      description: selectedCourse.description,
      image: selectedCourse.image,
      items: [
        {
          icon: "Calendar",
          label: "Inicio",
          value: selectedCourse.startDate,
        },
        {
          icon: "Clock",
          label: "Duración",
          value: selectedCourse.duration,
        },
        {
          icon: "Globe",
          label: "Modalidad",
          value: selectedCourse.modality,
        },
      ],
      footer: {
        label: "Precio",
        value: selectedCourse.price,
        subValue: selectedCourse.priceSubtext, 
        discountText: selectedCourse.formerStudentDiscount, 
      },
    }
  : null;
---

<Layout title="Inscripción a Cursos - Qualisophy">
  <div class="min-h-screen bg-gradient-to-b to-white py-12 px-4">
    <div class="max-w-7xl mx-auto">
      
      {/* BREADCRUMBS DINÁMICOS */}
      <nav class="text-sm text-slate-500 mb-8 flex flex-wrap items-center">
        <a href="/" class="hover:text-primary transition-colors">Inicio</a>
        <span class="mx-2 text-slate-400">/</span>
        <a href="/learning" class="hover:text-primary transition-colors">Cursos</a>
        
        {selectedCourse?.categorySlug && (
          <>
            <span class="mx-2 text-slate-400">/</span>
            <a href={`/learning/${selectedCourse.categorySlug}`} class="hover:text-primary transition-colors">
              {formatCategoryName(selectedCourse.categorySlug)}
            </a>
          </>
        )}
        
        {selectedCourse?.courseSlug && (
          <>
            <span class="mx-2 text-slate-400">/</span>
            <a href={`/learning/${selectedCourse.categorySlug}/${selectedCourse.courseSlug}`} class="hover:text-primary transition-colors truncate max-w-[200px] sm:max-w-xs">
              {selectedCourse.name}
            </a>
          </>
        )}

        <span class="mx-2 text-slate-400">/</span>
        <span class="text-slate-800 font-medium">Inscripción</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class:list={[courseCardData ? "lg:col-span-2" : "lg:col-span-3"]}>
          <h1
            class="text-2xl md:text-3xl lg:text-4xl font-bold mb-2 text-slate-800"
          >
            Inscripción al Curso
          </h1>
          <p class="text-slate-600 mb-8">
            Estás a un paso de comenzar tu aprendizaje. Completa tus datos para
            reservar tu plaza.
          </p>
          <CourseEnrollmentForm 
            client:load 
            courses={courses} 
            initialCourseId={courseId} 
          />
        </div>

        {
          courseCardData && (
            <div class="lg:col-span-1">
              <InstructorCard
                client:load
                title={courseCardData.title}
                description={courseCardData.description}
                image={courseCardData.image}
                items={courseCardData.items}
                footer={courseCardData.footer}
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</Layout>