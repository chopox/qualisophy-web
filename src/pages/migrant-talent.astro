---
import Layout from "@/layouts/Layout.astro";

// Importación de componentes reactivos
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { ProgramMethodology } from "@/components/react/programs/ProgramMethodology";
import { ProgramFeatures } from "@/components/react/programs/ProgramFeatures";
import { ProgramTestimonials } from "@/components/react/programs/ProgramTestimonials"; 
import { ProgramCTA } from "@/components/react/programs/ProgramCTA";

// --- DATOS DEL PROGRAMA ---

// FASE 1: Identificación
const mappingData = {
  title: "Identificación y Traducción de Talento",
  description: [
    "No hacemos simples evaluaciones. Ayudamos a las organizaciones a 'traducir' la experiencia internacional de sus beneficiarios al lenguaje del mercado local.",
    "Convertimos trayectorias no tradicionales en perfiles atractivos para empresas tecnológicas, identificando competencias transferibles que el CV estándar ignora."
  ],
  checks: [
    "Mapeo de Skills Técnicas y Transversales",
    "Traducción de Experiencia al Contexto Local",
    "Detección de Potencial de Liderazgo"
  ],
  imageSrc: "https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&q=80"
};

// FASE 2: Adaptación
const bridgeData = {
  title: "Adaptación Técnica y Cultural",
  description: [
    "El talento ya existe; solo necesita contexto. Creamos puentes formativos ágiles para cubrir las brechas específicas del mercado local.",
    "Preparamos a los candidatos no solo en tecnología, sino en la cultura corporativa y metodologías de trabajo de las empresas destino."
  ],
  checks: [
    "Upskilling en Herramientas Locales Demandadas",
    "Inmersión en Cultura Corporativa Ágil",
    "Mentoring para la Entrevista Técnica"
  ],
  imageSrc: "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80"
};

// PILARES DEL PROGRAMA
const pillarsFeatures = [
  {
    icon: "manage_search", 
    title: "Diagnóstico Integral",
    description: "Analizamos el perfil completo del candidato, más allá de los títulos, para entender su verdadero potencial de empleabilidad."
  },
  {
    icon: "school",
    title: "Nivelación Estratégica",
    description: "Formación quirúrgica para cerrar brechas técnicas específicas y aumentar la empleabilidad en tiempo récord."
  },
  {
    icon: "diversity_3",
    title: "Red de Mentores",
    description: "Acompañamiento psicosocial y profesional por parte de expertos del sector que guían la transición cultural."
  },
  {
    icon: "handshake",
    title: "Conexión Corporativa",
    description: "Intermediación directa con empresas partners comprometidas con la diversidad, facilitando la contratación final."
  }
];
---

<Layout 
  title="Talento Migrante - Qualisophy"
  description="Creamos alianzas estratégicas para la integración laboral de talento migrante y refugiado en el sector tecnológico."
  fullWidth={true}
>
  
  {/* 1. HERO - Fondo Azul */}
  <ProgramHero 
    client:load
    title="Alianzas que Transforman Vidas:" 
    highlight="Inclusión Tecnológica"
    subtitle="Colaboramos con ONGs e instituciones para conectar el talento global con oportunidades locales, creando un ecosistema de impacto real."
    backgroundImage="https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
    ctaText="Colaborar con Nosotros" 
  />

  {/* 2. METODOLOGÍA FASE 1 - Fondo BLANCO */}
  <ProgramMethodology 
    client:visible
    {...mappingData}
    reverse={false}
    variant="white"
  />

  {/* 3. METODOLOGÍA FASE 2 - Fondo GRIS */}
  {/* variant="blue" ahora renderiza fondo GRIS CLARO */}
  <ProgramMethodology 
    client:visible
    {...bridgeData}
    reverse={true}
    variant="blue"
  />

  {/* 4. PILARES - Fondo BLANCO */}
  <ProgramFeatures 
    client:visible
    title="Pilares de Intervención"
    subtitle="Un modelo integral diseñado para maximizar la tasa de éxito en la inserción laboral."
    features={pillarsFeatures}
    variant="light"
    layout="grid4" 
  />

  {/* 5. TESTIMONIOS - Fondo GRIS */}
  {/* variant="blue" -> GRIS CLARO */}
  <ProgramTestimonials 
    client:visible 
    variant="blue"
  />

  {/* 6. CTA FINAL - Fondo BLANCO */}
  <ProgramCTA 
    client:visible 
    variant="white"
  />

</Layout>