---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { CourseCatalogGrid } from "@/components/react/course/CourseCatalogGrid";
import { Newsletter } from "@/components/react/shared/Newsletter";

// Importamos el logo para usarlo como imagen de previsualización en redes sociales
import companyLogo from "@/assets/logo-q.png";

const heroBg = "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1600&q=80";

// Descripción basada en la propuesta de valor oficial
const siteDescription = "Ayudamos a personas en transición profesional y empresas tecnológicas a acceder a talento diverso y cualificado, evitando la exclusión para conseguir un empleo de calidad.";
---

<Layout 
  title="Qualisophy - Formación Tecnológica Inclusiva con IA"
  description={siteDescription}
  image={companyLogo.src}
  fullWidth={true}
>
  
  {/* HERO CATALOGO (Estilo Blog) */}
  <section class="relative w-full overflow-hidden min-h-[600px] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img
        src={heroBg}
        alt="Catálogo Formación Qualisophy"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    {/* Overlay azul corporativo */}
    <div class="absolute inset-0 z-0 bg-secondary/90 mix-blend-multiply"></div>

    <div class="relative z-10 container mx-auto px-6 text-center">
      <div class="max-w-4xl mx-auto flex flex-col gap-6">
        <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block drop-shadow-md">
          CATÁLOGO FORMATIVO
        </span>
        <h1 class="text-white text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight font-heading drop-shadow-md">
          Formación <span class="text-primary">Individual</span>
        </h1>
        <p class="text-gray-100 text-lg md:text-xl font-light leading-relaxed font-primary drop-shadow-sm max-w-2xl mx-auto">
          Impulsa tu carrera con nuestros itinerarios especializados. Domina las herramientas de QA, Datos, DevOps y Gestión Ágil.
        </p>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-6 pt-10">
    <Breadcrumbs />
  </div>

  {/* GRID INTERACTIVO DE CURSOS */}
  <CourseCatalogGrid client:load />

  {/* Newsletter */}
  <Newsletter client:visible />

</Layout>