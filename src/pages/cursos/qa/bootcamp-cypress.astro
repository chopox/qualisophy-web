---
import Layout from "@/layouts/Layout.astro";
import { Course } from "@/components/react/course/Course";
import { EnrollButton } from "@/components/react/shared/EnrollButton";
import Breadcrumbs from "@/components/Breadcrumbs.astro";

// Importamos la imagen del curso para redes sociales y la imagen del instructor
import courseImg from "@/assets/imagenes-cursos/qa/cypress-bootcamp.jpeg";
import instructorImg from "@/assets/instructor/instructor-javi.jpeg";

const courseDescription = "El Automation Testing permite a los equipos de QA mejorar radicalmente la eficiencia, la precisión y la velocidad de sus pruebas, reduciendo el time-to-market. Cypress se ha consolidado como la herramienta del momento gracias a su arquitectura moderna. En este bootcamp, los alumnos aprenderán Cypress desde cero, dominando desde los conceptos básicos hasta las técnicas de automatización y patrones de diseño más avanzados del mercado.";

const prerequisites = "Se recomienda contar con nociones básicas de pruebas de software manuales (como las impartidas en el curso base de QA) y conocimientos fundamentales de tecnologías web (HTML/CSS) y JavaScript.";

const modules = [
  {
    id: "1",
    number: 1,
    title: "Introducción a Cypress",
    description: "Análisis de la arquitectura de Cypress, instalación y configuración inicial.",
    topics: [
      "Estructura de carpetas y archivos de un proyecto estándar.",
      "Estrategias de identificación de elementos (Localizadores).",
      "Implementación de aserciones (Asserts) nativas de la herramienta."
    ],
    icon: "Terminal",
  },
  {
    id: "2",
    number: 2,
    title: "Comandos Básicos e Interacción con UI",
    description: "Domina la navegación y manipulación del DOM.",
    topics: [
      "Simulación de acciones del usuario (clic, escritura, selección).",
      "Interacción avanzada con Checkboxes, Radio Buttons y Dropdowns.",
      "Manejo e intercepción de alertas, ventanas emergentes y tablas dinámicas."
    ],
    icon: "Layout",
  },
  {
    id: "3",
    number: 3,
    title: "Buenas Prácticas y Patrones de Diseño",
    description: "Escribe código limpio y frameworks mantenibles.",
    topics: [
      "Uso estratégico de Fixtures para la gestión de datos de prueba externos.",
      "Creación y mantenimiento de Custom Commands.",
      "Implementación del Patrón de Diseño Page Object Model (POM).",
      "Configuración de variables globales y manejo de Retries (flaky tests)."
    ],
    icon: "Code",
  },
  {
    id: "4",
    number: 4,
    title: "Otras Funcionalidades",
    description: "Lleva Cypress al siguiente nivel validando APIs y BDD.",
    topics: [
      "Validación integral de APIs (Backend) utilizando Cypress.",
      "Estrategias de ejecución de pruebas multiplataforma.",
      "Configuración y análisis de métricas usando Cypress Dashboard.",
      "Introducción a la integración de Cucumber (BDD)."
    ],
    icon: "Database",
  }
];

const instructor = {
  name: "Javier Flores",
  title: "Instructor Tech · Automatización QA",
  experience: "Experiencia en entornos Agile y CI/CD",
  description: "QA Lead y Cypress Ambassador comprometido con la implementación de la calidad mediante automatización y diseño de frameworks mantenibles.",
  image: instructorImg.src, 
  certifications: [
    "Cypress Ambassador 2026",
    "ISTQB Foundation Level"
  ],
};

const courseDetails = {
  startDate: "28 de Abril de 2026",
  duration: "36 horas (6 semanas)",
  schedule: "Martes y Jueves / 18:00 - 21:00",
  regularPrice: "547 €",
  earlyBirdPrice: "497 € (antes del 3 de Abril)", 
};

const courseId = "qa-cypress";
const courseName = "Cypress Automation Bootcamp";
---

<Layout 
  title={`${courseName} - Qualisophy`}
  description={courseDescription.substring(0, 160) + "..."}
  image={courseImg.src}
  fullWidth={true}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6"><Breadcrumbs /></div>
    <h1 class="text-center text-2xl md:text-3xl font-bold text-slate-800 mb-8 md:mb-16">
      {courseName}
    </h1>
    <Course 
      client:load 
      modules={modules} 
      instructor={instructor} 
      courseDetails={courseDetails} 
      courseId={courseId}
      courseDescription={courseDescription}
      prerequisites={prerequisites}
    />
    <EnrollButton 
      client:load 
      courseId={courseId} 
      courseName={courseName} 
      isComingSoon={courseDetails.startDate.toLowerCase().includes("por definir")}
    />
  </div>
</Layout>