---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { Newsletter } from "@/components/react/shared/Newsletter";

// ⚠️ IMPORTANTE: Renderizado estático
export const prerender = true;

export async function getStaticPaths() {
  const posts = [
    { 
      slug: "impacto-ia-testing", 
      title: "El impacto de la IA en el testing de software moderno",
      category: "Tendencias",
      date: "12 Oct, 2024",
      image: "https://images.unsplash.com/photo-1620712943543-bcc4688e7485?auto=format&fit=crop&q=80&w=2070"
    },
    { 
      slug: "neurodivergencia-ventaja", 
      title: "Neurodivergencia: La ventaja competitiva oculta",
      category: "Inclusión",
      date: "28 Sep, 2024",
      image: "https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&q=80&w=2070"
    },
    { 
      slug: "caso-exito-maria", 
      title: "De la hostelería a Desarrollador Full Stack en 6 meses",
      category: "Casos de Éxito",
      date: "15 Sep, 2024",
      image: "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=2070"
    },
    { 
      slug: "powerbi-negocios", 
      title: "Power BI: Transformando datos en decisiones estratégicas",
      category: "Tecnología",
      date: "10 Sep, 2024",
      image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=2070"
    },
    { 
      slug: "diversidad-equipos-agiles", 
      title: "Cómo gestionar la diversidad en equipos ágiles",
      category: "Inclusión",
      date: "05 Sep, 2024",
      image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=2070"
    },
  ];
  
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect("/404");
}
---

<Layout 
  title={`${post.title} - Blog Qualisophy`}
  description={`Artículo sobre ${post.category} en Qualisophy`}
  fullWidth={true}
>
  
  {/* HERO ARTÍCULO */}
  <section class="relative w-full overflow-hidden min-h-[600px] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 z-0 bg-secondary/90 mix-blend-multiply"></div>

    <div class="relative z-10 container mx-auto px-6 text-center">
      <div class="max-w-5xl mx-auto flex flex-col items-center gap-6">
        
        {/* Etiqueta Categoría */}
        <span class="bg-primary text-white px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider shadow-sm">
          {post.category}
        </span>
        
        {/* Título Grande */}
        <h1 class="text-white text-3xl md:text-5xl lg:text-6xl font-bold font-heading leading-tight drop-shadow-md">
          {post.title}
        </h1>

        {/* Metadatos (Fecha y Lectura) */}
        <div class="flex flex-wrap items-center justify-center gap-6 text-blue-100 text-base md:text-lg font-primary mt-2">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined">calendar_today</span>
            <span>{post.date}</span>
          </div>
          <div class="w-1.5 h-1.5 bg-primary rounded-full hidden md:block"></div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined">schedule</span>
            <span>5 min de lectura</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* CONTENIDO DEL ARTÍCULO */}
  <article class="bg-white py-16">
    <div class="container mx-auto px-6 max-w-3xl">
      
      <Breadcrumbs />
      
      <div class="prose prose-lg prose-slate mt-10 max-w-none">
        <p class="lead text-xl md:text-2xl text-slate-600 font-light italic mb-10 leading-relaxed border-l-4 border-primary pl-6">
          Este es un extracto introductorio del artículo sobre <strong>{post.title}</strong>. Aquí se resume la idea principal para enganchar al lector desde el primer párrafo.
        </p>

        <h2 class="text-secondary font-heading text-2xl md:text-3xl font-bold mt-12 mb-6">La revolución tecnológica</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>
        <p>
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
        </p>

        <div class="my-10 p-8 bg-blue-50/50 border border-blue-100 rounded-2xl shadow-sm">
          <p class="font-bold text-secondary mb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">lightbulb</span> 
            Dato Clave
          </p>
          <p class="text-slate-700 m-0 text-lg">El 85% de los trabajos que existirán en 2030 aún no se han inventado, según un informe de Dell Technologies.</p>
        </div>

        <h2 class="text-secondary font-heading text-2xl md:text-3xl font-bold mt-12 mb-6">El factor humano</h2>
        <p>
          Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam, eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae dicta sunt explicabo.
        </p>
        
        <ul class="list-disc pl-6 space-y-3 text-slate-700 my-6">
          <li><strong>Adaptabilidad cognitiva:</strong> La capacidad de aprender a aprender.</li>
          <li><strong>Resiliencia emocional:</strong> Gestión del cambio constante.</li>
          <li><strong>Aprendizaje continuo:</strong> La filosofía del Life-long learning.</li>
        </ul>

        <p>
          Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.
        </p>
      </div>

      {/* --- SECCIÓN DE COMPARTIR FUNCIONAL --- */}
      <div class="mt-16 pt-10 border-t border-slate-100">
        <p class="font-bold text-secondary mb-4 text-center">¿Te ha gustado? Compártelo:</p>
        <div class="flex gap-4 justify-center">
          
          {/* Botón Native Share */}
          <button 
            id="share-btn"
            class="group w-12 h-12 rounded-full bg-slate-50 text-slate-600 border border-slate-200 flex items-center justify-center hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 shadow-sm"
            aria-label="Compartir en redes"
          >
            <span class="material-symbols-outlined text-xl group-hover:scale-110 transition-transform">share</span>
          </button>
          
          {/* Botón Copiar Link */}
          <button 
            id="copy-link-btn"
            class="group w-12 h-12 rounded-full bg-slate-50 text-slate-600 border border-slate-200 flex items-center justify-center hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 shadow-sm relative"
            aria-label="Copiar enlace"
          >
            <span id="copy-icon" class="material-symbols-outlined text-xl group-hover:scale-110 transition-transform">link</span>
            
            {/* Tooltip "Copiado" */}
            <span id="copy-tooltip" class="absolute -top-10 left-1/2 -translate-x-1/2 bg-secondary text-white text-xs font-bold py-1 px-3 rounded shadow-lg opacity-0 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
              ¡Copiado!
            </span>
          </button>

        </div>
      </div>

    </div>
  </article>

  <Newsletter client:visible/>

</Layout>

{/* SCRIPT PARA MANEJAR LA FUNCIONALIDAD */}
<script>
  // Ejecutamos cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    const shareBtn = document.getElementById('share-btn');
    const copyLinkBtn = document.getElementById('copy-link-btn');
    const copyIcon = document.getElementById('copy-icon');
    const copyTooltip = document.getElementById('copy-tooltip');

    // 1. Lógica Botón Share (Nativo)
    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        const shareData = {
          title: document.title,
          text: '¡Echa un vistazo a este artículo de Qualisophy!',
          url: window.location.href,
        };

        // Si el navegador soporta compartir nativo (móviles, Mac, etc.)
        if (navigator.share) {
          try {
            await navigator.share(shareData);
          } catch (err) {
            console.log('Error al compartir:', err);
          }
        } else {
          // Si no soporta share nativo, hacemos fallback a copiar enlace
          copyToClipboard();
        }
      });
    }

    // 2. Lógica Botón Copiar Link
    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', () => {
        copyToClipboard();
      });
    }

    // Función auxiliar para copiar y mostrar feedback
    async function copyToClipboard() {
      try {
        await navigator.clipboard.writeText(window.location.href);
        
        // Feedback Visual
        if (copyIcon && copyTooltip) {
          const originalIcon = copyIcon.textContent;
          
          // Cambiamos icono a check
          copyIcon.textContent = 'check';
          
          // Mostramos tooltip
          copyTooltip.classList.remove('opacity-0');
          copyTooltip.classList.add('opacity-100', '-translate-y-1');

          // Restauramos después de 2 segundos
          setTimeout(() => {
            copyIcon.textContent = originalIcon;
            copyTooltip.classList.remove('opacity-100', '-translate-y-1');
            copyTooltip.classList.add('opacity-0');
          }, 2000);
        }
      } catch (err) {
        console.error('Error al copiar al portapapeles:', err);
      }
    }
  });
</script>