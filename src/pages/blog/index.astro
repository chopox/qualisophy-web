---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { BlogGrid } from "@/components/react/blog/BlogGrid";
import { Newsletter } from "@/components/react/shared/Newsletter";

const heroBg = "https://images.unsplash.com/photo-1499750310159-52f0f826351b?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80";
---

<Layout 
  title="Blog Qualisophy - Tecnología e Inclusión"
  description="Artículos sobre tendencias tecnológicas, diversidad y desarrollo profesional."
  fullWidth={true}
>
  
  {/* HERO BLOG */}
  <section class="relative w-full overflow-hidden min-h-[400px] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img
        src={heroBg}
        alt="Blog Header"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    <div class="absolute inset-0 z-0 bg-secondary/90 mix-blend-multiply"></div>

    <div class="relative z-10 container mx-auto px-6 text-center">
      <h1 class="text-white text-4xl md:text-5xl font-bold font-heading mb-4 drop-shadow-md">
        Blog & <span class="text-primary">Actualidad</span>
      </h1>
      <p class="text-blue-100 text-lg max-w-2xl mx-auto">
        Insights, historias de éxito y las últimas tendencias del sector.
      </p>
    </div>
  </section>

  <div class="container mx-auto px-6 pt-8">
    <Breadcrumbs />
  </div>

  {/* GRID INTERACTIVO */}
  <BlogGrid client:load />

  {/* Newsletter */}
  <Newsletter />

</Layout>