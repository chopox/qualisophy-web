---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { BlogGrid } from "@/components/react/blog/BlogGrid";
import { Newsletter } from "@/components/react/shared/Newsletter";

const heroBg = "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=2070";
---

<Layout 
  title="Blog Qualisophy - Tecnología e Inclusión"
  description="Artículos sobre tendencias tecnológicas, diversidad y desarrollo profesional."
  fullWidth={true}
>
  
  {/* HERO BLOG (Igualado a Team/Home) */}
  <section class="relative w-full overflow-hidden min-h-[600px] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img
        src={heroBg}
        alt="Blog Header"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    {/* Overlay azul corporativo */}
    <div class="absolute inset-0 z-0 bg-secondary/90 mix-blend-multiply"></div>

    <div class="relative z-10 container mx-auto px-6 text-center">
      <div class="max-w-4xl mx-auto flex flex-col gap-6">
        <h1 class="text-white text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight font-heading drop-shadow-md">
          Blog & <span class="text-primary">Actualidad</span>
        </h1>
        <p class="text-gray-100 text-lg md:text-xl font-light leading-relaxed font-primary drop-shadow-sm max-w-2xl mx-auto">
          Insights, historias de éxito y las últimas tendencias del sector.
        </p>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-6 pt-10">
    <Breadcrumbs />
  </div>

  {/* GRID INTERACTIVO */}
  <BlogGrid client:load />

  {/* Newsletter */}
  <Newsletter />

</Layout>