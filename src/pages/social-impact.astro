---
import Layout from "@/layouts/Layout.astro";

// Componentes Reutilizables
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { ProgramMethodology } from "@/components/react/programs/ProgramMethodology";
import { ProgramFeatures } from "@/components/react/programs/ProgramFeatures";
import { ProgramCTA } from "@/components/react/programs/ProgramCTA";

// --- DATOS: RIESGO DE EXCLUSIÓN (Enfoque B2B Social) ---

const techTrainingData = {
  title: "Formación Técnica Adaptada a la Realidad del Mercado",
  description: [
    "Convertimos la brecha digital en un puente hacia el empleo digno. No enseñamos tecnología por enseñar; capacitamos para la empleabilidad real.",
    "Utilizamos metodologías ágiles diseñadas específicamente para perfiles diversos, asegurando que personas fuera del sistema educativo tradicional puedan adquirir competencias IT demandadas."
  ],
  checks: [
    "Metodología Práctica (Learning by Doing)",
    "Adaptabilidad Curricular por Perfil",
    "Foco en Competencias de Alta Demanda"
  ],
  imageSrc: "https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&q=80" 
};

const psychoSupportData = {
  title: "Más que código: Reconstrucción de la Identidad Profesional",
  description: [
    "Sabemos que la técnica no basta. Nuestro equipo de psicólogos acompaña al usuario para fortalecer su autoestima, resiliencia y autoeficacia.",
    "Trabajamos la estabilidad emocional y las habilidades socioemocionales necesarias no solo para conseguir el empleo, sino para mantenerlo a largo plazo."
  ],
  checks: [
    "Fortalecimiento de Autoestima y Confianza",
    "Desarrollo de Resiliencia Laboral",
    "Acompañamiento Integral Personalizado"
  ],
  imageSrc: "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?auto=format&fit=crop&q=80"
};

const communitiesFeatures = [
  {
    icon: "groups", // Icono claro de grupo/comunidad
    title: "Entorno Seguro e Inclusivo",
    description: "Creamos espacios donde la herencia cultural y la identidad se valoran como activos, fomentando la pertenencia y la seguridad psicológica."
  },
  {
    icon: "handshake", // Icono de apoyo/mentoria
    title: "Mentoría y Red de Apoyo",
    description: "Conectamos a los usuarios con mentores que guían su camino, ofreciendo referentes positivos y una red de contactos profesional."
  },
  {
    icon: "public",
    title: "Diversidad como Valor",
    description: "Transformamos la experiencia multicultural en una ventaja competitiva para las empresas, promoviendo la innovación desde la diversidad."
  },
  {
    icon: "rocket_launch",
    title: "Segunda Oportunidad Real",
    description: "Facilitamos la reinvención profesional efectiva, abriendo puertas en un sector con futuro para quienes buscan un nuevo comienzo."
  }
];

const resourcesFeatures = [
  {
    icon: "groups", // CAMBIO: Networking en lugar de dinero
    title: "Networking Estratégico",
    description: "Rompemos el aislamiento profesional conectando al alumno con una red exclusiva de mentores y expertos en activo dentro del ecosistema tecnológico."
  },
  {
    icon: "devices", 
    title: "Dotación Tecnológica",
    description: "Facilitamos el acceso a equipos informáticos y conectividad para asegurar que todos los alumnos dispongan de las herramientas profesionales necesarias."
  },
  {
    icon: "school", 
    title: "Tutorización Experta",
    description: "Seguimiento académico cercano con profesionales del sector que resuelven dudas y adaptan el ritmo de aprendizaje."
  },
  {
    icon: "work", 
    title: "Inserción Laboral Asistida",
    description: "Nuestro objetivo es el empleo. Conectamos directamente con empresas partners y acompañamos en todo el proceso de selección."
  }
];
---

<Layout 
  title="Riesgo de Exclusión - Qualisophy"
  description="Alianzas estratégicas para la inserción laboral de colectivos vulnerables a través de la tecnología."
  fullWidth={true}
>
  
  {/* 1. HERO - Fondo Azul (Imagen + Overlay fuerte) */}
  <ProgramHero 
    client:load
    title={"Transformamos vidas a través de la tecnología:"}
    highlight={"Alianza estratégica para la inclusión"}
    subtitle="Somos el puente entre el talento de vuestros usuarios y el mercado laboral tecnológico. Creamos oportunidades reales de empleo digno."
    backgroundImage="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80"
    ctaText="Colabora con nosotros" 
  />

  {/* 2. FASE 1: Capacitación Digital - Fondo BLANCO */}
  <ProgramMethodology 
    client:visible
    {...techTrainingData}
    reverse={false}
    variant="white"
  />

  {/* 3. FASE 2: Acompañamiento Psicosocial - Fondo AZUL (Alternancia) */}
  <ProgramMethodology 
    client:visible
    {...psychoSupportData}
    reverse={true}
    variant="blue"
  />

  {/* 4. COMUNIDADES (Entorno Seguro) - Fondo BLANCO */}
  <ProgramFeatures 
    client:visible
    title="Comunidad y Pertenencia"
    subtitle="Construimos redes de seguridad que combaten el aislamiento y fomentan el crecimiento."
    features={communitiesFeatures}
    variant="light" 
    layout="grid4" 
  />

  {/* 5. RECURSOS (Éxito Compartido) - Fondo AZUL */}
  <ProgramFeatures 
    client:visible
    title="Recursos para el Éxito Compartido"
    subtitle="Nos encargamos de las barreras operativas y financieras para garantizar resultados."
    features={resourcesFeatures}
    variant="dark" 
    layout="cards" 
  />

  {/* 6. CTA FINAL - Fondo BLANCO (Cierre B2B) */}
  <ProgramCTA 
    client:visible 
    variant="white"
  />

</Layout>