---
import Layout from "@/layouts/Layout.astro";

// Importación de Componentes
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { ProgramMethodology } from "@/components/react/programs/ProgramMethodology";
import { ProgramFeatures } from "@/components/react/programs/ProgramFeatures";
import { ProgramCurriculum } from "@/components/react/programs/ProgramCurriculum";
import { ProgramCTA } from "@/components/react/programs/ProgramCTA";
import { TalentReality } from "@/components/react/talent/TalentReality";
import { TalentBarriers } from "@/components/react/talent/TalentBarriers";
import { TalentImpact } from "@/components/react/talent/TalentImpact";
import { LegalCompliance } from "@/components/react/talent/LegalCompliance";
import { SocialImpactQuote } from "@/components/react/talent/SocialImpactQuote";

// --- DATOS: RIESGO DE EXCLUSIÓN ---

const realityStats = [
  { 
    value: "26,5%", 
    label: "Tasa AROPE", 
    description: "Uno de cada cuatro residentes en España se encuentra en riesgo de pobreza o exclusión social.", 
    icon: "home_work", 
    colorClass: "text-primary" 
  },
  { 
    value: "13,7%", 
    label: "Trabajadores Pobres", 
    description: "El empleo precario no es suficiente; el objetivo es la inserción en puestos estables y autosuficientes.", 
    icon: "payments", 
    colorClass: "text-primary" 
  },
  { 
    value: "+ Alta", 
    label: "Interseccionalidad", 
    description: "Las mujeres extranjeras sufren una sobrecualificación aún mayor, sumando barreras de género y origen.", 
    icon: "groups", 
    colorClass: "text-primary" 
  }
];

const barrierList = [
  { 
    icon: "lock_clock", 
    title: "Acceso Limitado", 
    description: "Estigmas sociales hacia mayores de 45 años y parados de larga duración que bloquean el acceso a entrevistas." 
  },
  { 
    icon: "family_restroom", 
    title: "Mantenimiento", 
    description: "Inestabilidad personal por falta de vivienda o precariedad estructural en sectores de bajo valor (hostelería, limpieza)." 
  },
  { 
    icon: "school", 
    title: "Promoción", 
    description: "Falta de formación continua y digitalización que cronifica la permanencia en puestos de baja cualificación." 
  }
];

const impactList = [
  "Aumento significativo de la autonomía y reducción de la dependencia de ayudas.",
  "Mayor cohesión social e integración en la comunidad local.",
  "Acceso a una vida independiente y estabilidad familiar.",
  "Recuperación de la identidad y dignidad profesional."
];

const legalItems = [
  { 
    percentage: 100, 
    label: "Bonificaciones", 
    description: "Ahorros de hasta 1.300 €/año en cuotas de Seguridad Social por contratar colectivos vulnerables." 
  },
  { 
    percentage: 100, 
    label: "Cumplimiento", 
    description: "Mejora del cumplimiento de los criterios ESG y responsabilidad social corporativa (RSC)." 
  }
];

const strategySkills = {
  title: "Estrategia 1: Reciclaje y Habilidades",
  description: [
    "La tecnología es el gran igualador. Ofrecemos capacitación intensiva en herramientas digitales básicas y competencias blandas.",
    "Combinamos esto con Formación Dual para que el aprendizaje genere ingresos desde el primer momento."
  ],
  checks: [
    "Alfabetización Digital Acelerada",
    "Soft Skills e Inteligencia Emocional",
    "Formación Dual Remunerada"
  ],
  imageSrc: "https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&q=80"
};

const strategyAccess = [
  { 
    icon: "support", 
    title: "Acompañamiento Social", 
    description: "Apoyo psicológico y mediación para estabilizar el entorno personal (vivienda, conciliación)." 
  },
  { 
    icon: "handshake", 
    title: "Intermediación Proactiva", 
    description: "Alianzas estratégicas con ONGs para asegurar el encaje perfecto entre perfil y vacante." 
  },
  { 
    icon: "security", 
    title: "Seguimiento Post-Inserción", 
    description: "Prevención de bajas tempranas mediante apoyo constante tanto al trabajador como a la empresa." 
  },
  { 
    icon: "computer", 
    title: "Dotación Tecnológica", 
    description: "Facilitamos el acceso a equipos informáticos y conectividad para eliminar la brecha digital." 
  }
];

const itinerarySteps = [
  { 
    stepNumber: 1, 
    title: "Evaluación Integral", 
    description: "Diagnóstico profundo de la situación social, económica y competencias formativas." 
  },
  { 
    stepNumber: 2, 
    title: "Planificación de Metas", 
    description: "Hoja de ruta para eliminar barreras externas (brecha digital, situación legal, logística)." 
  },
  { 
    stepNumber: 3, 
    title: "Entrenamiento en Puesto", 
    description: "Prácticas tutorizadas para recuperar la confianza y la identidad profesional." 
  },
  { 
    stepNumber: 4, 
    title: "Autonomía Laboral", 
    description: "Consolidación en un puesto estable con proyección de carrera a largo plazo." 
  }
];

const ctaButtons = [
  { label: "Contrata con Impacto Social", href: "/contact?type=company", variant: "solid" as const },
  { label: "Solicita Acompañamiento", href: "/contact?type=candidate", variant: "outline" as const }
];
---

<Layout 
  title="Riesgo de Exclusión - Qualisophy" 
  description="Inclusión laboral para colectivos vulnerables. Rompemos el ciclo de exclusión mediante el empleo digno." 
  fullWidth={true}
>
  
  {/* SECCIÓN 0: HERO (Con ID de scroll) */}
  <ProgramHero 
    client:load
    title="Transformando la Vulnerabilidad en Autonomía:" 
    highlight="Inclusión Laboral"
    subtitle="Facilitamos la reincorporación al mercado de colectivos desfavorecidos para romper el ciclo de la exclusión mediante el empleo digno."
    backgroundImage="https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?auto=format&fit=crop&q=80"
    ctaText="Ver Itinerario"
    scrollToId="itinerario"
  />

  {/* SECCIÓN 1: REALIDAD */}
  <TalentReality 
    client:load 
    title="Una Realidad Preocupante" 
    subtitle="Contexto Social"
    description="La exclusión social no es solo un problema económico, es una pérdida de capital humano para toda la sociedad."
    stats={realityStats}
  />

  {/* SECCIÓN 2: BARRERAS */}
  <TalentBarriers client:load barriers={barrierList} />

  {/* SECCIÓN 3: IMPACTO */}
  <TalentImpact 
    client:load 
    items={impactList} 
    imageSrc="https://images.unsplash.com/photo-1455849318743-b2233052fcff?auto=format&fit=crop&q=80"
  />

  {/* SECCIÓN 4: MARCO LEGAL */}
  <LegalCompliance 
    client:load 
    title="Marco Legal: El Valor de la Inclusión"
    items={legalItems}
    footerText="Las empresas socialmente responsables no solo mejoran su imagen, sino que se benefician de importantes incentivos fiscales."
  />

  {/* SECCIÓN 5: ESTRATEGIA 1 */}
  <ProgramMethodology 
    client:visible
    {...strategySkills}
    variant="white"
  />

  {/* SECCIÓN 6: ESTRATEGIA 2 */}
  <ProgramFeatures 
    client:visible
    title="Estrategia 2: Facilitar Acceso"
    subtitle="Soporte integral para garantizar la estabilidad laboral."
    features={strategyAccess}
    variant="dark"
    layout="grid4"
  />

  {/* SECCIÓN 7: ITINERARIOS (Destino del scroll) */}
  <div id="itinerario" class="scroll-mt-32">
    <ProgramCurriculum 
      client:visible
      title="Itinerarios Personalizados: Clave del Éxito"
      subtitle="Un camino estructurado para recuperar la autonomía y dignidad profesional."
      steps={itinerarySteps}
      variant="white"
    />
  </div>

  {/* SECCIÓN 8: CITA FINAL */}
  <SocialImpactQuote client:load />

  {/* SECCIÓN 9: CTA */}
  <div id="program-cta">
    <ProgramCTA 
      client:visible 
      title="Construye un Futuro Inclusivo"
      description="Tu empresa puede ser el motor de cambio que alguien necesita. Únete a la red inclusiva."
      buttons={ctaButtons}
      variant="white"
    />
  </div>

</Layout>