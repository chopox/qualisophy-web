---
import Layout from "@/layouts/Layout.astro";

// Componentes React
import { HeroSection } from "@/components/react/home/HeroSection";
import { AboutSection } from "@/components/react/home/AboutSection"; // NUEVO
import { MissionSection } from "@/components/react/home/MissionSection";
import { InclusionPillars } from "@/components/react/home/InclusionPillars";
import { ValuesSection } from "@/components/react/home/ValuesSection";
import { Newsletter } from "@/components/react/shared/Newsletter";
---

<Layout 
  title="Qualisophy - Inclusión Tecnológica" 
  fullWidth={true} 
>
  
  {/* 1. HERO (Imagen Completa) */}
  <HeroSection client:load />

  {/* 2. IDENTIDAD / QUIÉNES SOMOS (Fondo Blanco - Imagen Izquierda) */}
  <AboutSection />

  {/* 3. MISIÓN / OBJETO SOCIAL (Fondo Blanco - Imagen Derecha) */}
  <MissionSection />

  {/* 4. VALORES (Fondo Gris Claro) */}
  <ValuesSection />

  {/* 5. PILARES (Fondo Blanco) */}
  <InclusionPillars client:load />

{/* 6. NEWSLETTER (Fondo Blanco) */}
<Newsletter client:visible variant="white" />

</Layout>