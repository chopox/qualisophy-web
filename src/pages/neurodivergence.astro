---
import Layout from "@/layouts/Layout.astro";

// Importación de Componentes
import { ProgramHero } from "@/components/react/programs/ProgramHero";
import { ProgramMethodology } from "@/components/react/programs/ProgramMethodology";
import { ProgramFeatures } from "@/components/react/programs/ProgramFeatures";
import { ProgramCurriculum } from "@/components/react/programs/ProgramCurriculum";
import { ProgramCTA } from "@/components/react/programs/ProgramCTA";

// Componentes de Talento (Ahora dinámicos)
import { TalentReality } from "@/components/react/talent/TalentReality";
import { TalentBarriers } from "@/components/react/talent/TalentBarriers";
import { TalentImpact } from "@/components/react/talent/TalentImpact";
import { LegalCompliance } from "@/components/react/talent/LegalCompliance";
import { SocialImpactQuote } from "@/components/react/talent/SocialImpactQuote";

// --- DATOS: REALIDAD NEURODIVERGENTE (Extraídos de tu versión anterior) ---

const realityStats = [
  { 
    value: "85%", 
    label: "Tasa de Desempleo", 
    description: "Personas adultas con autismo sin actividad laboral productiva.", 
    icon: "trending_down", 
    colorClass: "text-primary" 
  },
  { 
    value: "34%", 
    label: "Tasa de Actividad", 
    description: "Frente al 77,7% de personas sin discapacidad.", 
    icon: "person_off", 
    colorClass: "text-primary" 
  },
  { 
    value: "50%", 
    label: "Incumplimiento LGD", 
    description: "De las empresas obligadas aún no cumplen la cuota de reserva del 2%.", 
    icon: "gavel", 
    colorClass: "text-primary" 
  }
];

const barrierList = [
  { 
    icon: "block", 
    title: "Acceso Limitado", 
    description: "Dificultades para conseguir el primer empleo debido a prejuicios y desconocimiento empresarial sobre las capacidades del colectivo." 
  },
  { 
    icon: "engineering", 
    title: "Mantenimiento", 
    description: "Problemas para conservar el trabajo por falta de adaptaciones y apoyos específicos (sensoriales y organizativos)." 
  },
  { 
    icon: "trending_flat", 
    title: "Promoción", 
    description: "Escasas oportunidades de crecimiento y desarrollo de carrera, limitando su potencial de contribución a largo plazo." 
  }
];

const impactList = [
  "Aumento significativo de la autoestima y satisfacción personal.",
  "Mayor participación social e integración comunitaria.",
  "Desarrollo de autonomía y autodeterminación.",
  "Acceso a vida independiente y autosuficiencia económica."
];

const legalItems = [
  { 
    percentage: 2, 
    label: "Cuota Legal", 
    description: "Porcentaje mínimo de plantilla con discapacidad exigido por ley a empresas de +50 empleados." 
  },
  { 
    percentage: 50, 
    label: "Incumplimiento", 
    description: "Estimación de empresas obligadas que actualmente no alcanzan el porcentaje o medidas alternativas." 
  }
];

// --- DATOS SECCIÓN 5: ESTRATEGIA 1 (Formación Dual) ---
const dualTrainingData = {
  title: "Estrategia 1: Formación Dual",
  description: [
    "La Formación Dual actúa como un puente seguro hacia el empleo. Combinamos la adquisición de conocimientos técnicos con la experiencia directa en la empresa.",
    "Este modelo permite una adaptación progresiva, reduciendo la incertidumbre tanto para el candidato como para la empresa contratante."
  ],
  checks: [
    "Formación Teórica: Conocimientos adaptados.",
    "Práctica Empresarial: Experiencia en entornos reales.",
    "Inserción Laboral: Transición con garantías."
  ],
  imageSrc: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2070&auto=format&fit=crop"
};

// --- DATOS SECCIÓN 6: ESTRATEGIA 2 (Facilitar Acceso) ---
const strategyFeatures = [
  {
    icon: "handshake",
    title: "Empleo con Apoyo",
    description: "Acompañamiento especializado durante todo el proceso de integración laboral y seguimiento continuado."
  },
  {
    icon: "compass_calibration",
    title: "Orientación Profesional",
    description: "Servicios de intermediación sociolaboral y asesoramiento personalizado para cada perfil."
  },
  {
    icon: "diversity_3",
    title: "Unidades Especializadas",
    description: "Equipos expertos en discapacidad que faciliten la conexión entre talento y oportunidades."
  },
  {
    icon: "psychology",
    title: "Adaptación Técnica",
    description: "Ajuste de puestos y herramientas para maximizar el rendimiento del talento neurodivergente."
  }
];

// --- DATOS SECCIÓN 7: ITINERARIOS (4 Pasos) ---
const itinerarySteps = [
  {
    stepNumber: 1,
    title: "Evaluación Individual",
    description: "Análisis de capacidades, intereses y necesidades específicas de apoyo."
  },
  {
    stepNumber: 2,
    title: "Planificación Adaptada",
    description: "Diseño de rutas formativas y profesionales ajustadas a cada persona."
  },
  {
    stepNumber: 3,
    title: "Acompañamiento Continuo",
    description: "Seguimiento y adaptación del itinerario según evolución y logros."
  },
  {
    stepNumber: 4,
    title: "Inserción Sostenible",
    description: "Integración laboral exitosa con perspectiva de desarrollo profesional."
  }
];

// CTA Personalizado (Opcional, si no se pasa usa el default)
const ctaButtons = [
  { label: "Agendar Consulta", href: "/contact", variant: "solid" as const },
  { label: "Ver Programas Arriba", href: "#", variant: "outline" as const }
];

---

<Layout 
  title="Talento Neurodivergente - Qualisophy"
  description="Inclusión laboral de personas con autismo. Formación dual y estrategias para empresas."
  fullWidth={true}
>
  
  {/* SECCIÓN 0: HERO */}
  <ProgramHero 
    client:load
    title={"Potenciando Habilidades Únicas:"} 
    highlight={"Talento Neurodivergente"}
    subtitle="Programas diseñados para la inclusión de personas con TDAH y Autismo en el sector tecnológico."
    backgroundImage="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=2069&auto=format&fit=crop"
    onCtaClick={() => document.getElementById('program-cta')?.scrollIntoView({ behavior: 'smooth' })}
  />

  {/* SECCIÓN 1: REALIDAD (Datos corregidos) */}
  <TalentReality 
    client:load 
    title="El Talento Oculto"
    subtitle="Una Realidad Preocupante"
    description="El autismo presenta la tasa más alta de desempleo entre todos los colectivos de discapacidad, a pesar de contar con las cualificaciones técnicas necesarias."
    stats={realityStats} 
  />

  {/* SECCIÓN 2: BARRERAS (Datos corregidos) */}
  <TalentBarriers 
    client:load 
    barriers={barrierList} 
  />

  {/* SECCIÓN 3: IMPACTO (Datos corregidos) */}
  <TalentImpact 
    client:load 
    items={impactList} 
  />

  {/* SECCIÓN 4: MARCO LEGAL (Datos corregidos) */}
  <LegalCompliance 
    client:load 
    items={legalItems} 
    footerText="La Ley General de Discapacidad (LGD) establece obligaciones claras, pero su cumplimiento sigue siendo un reto. En Qualisophy te ayudamos a convertir este requisito en una ventaja estratégica."
  />

  {/* SECCIÓN 5: ESTRATEGIA 1 - FORMACIÓN DUAL */}
  <ProgramMethodology 
    client:visible
    {...dualTrainingData}
    variant="white"
  />

  {/* SECCIÓN 6: ESTRATEGIA 2 - ACCESO */}
  <ProgramFeatures 
    client:visible
    title="Estrategia 2: Facilitar Acceso"
    subtitle="Mecanismos de apoyo para conectar talento y empresa."
    features={strategyFeatures}
    variant="dark"  
    layout="grid4" 
  />

  {/* SECCIÓN 7: ITINERARIOS */}
  <ProgramCurriculum 
    client:visible
    title="Itinerarios Personalizados: Clave del Éxito"
    subtitle="Un proceso estructurado para garantizar resultados."
    steps={itinerarySteps}
    variant="white" 
  />

  {/* SECCIÓN 8: INCLUSIÓN REAL + CITA */}
  <SocialImpactQuote client:load />

  {/* SECCIÓN 9: CTA */}
  <div id="program-cta">
    <ProgramCTA 
      client:visible 
      variant="white"
      buttons={ctaButtons}
    />
  </div>

</Layout>