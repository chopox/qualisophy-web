---
/**
 * Main layout wrapping all site pages.
 */

import "@/styles/global.css";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Sidebar } from "@/components/react/layout/Sidebar";
import { ChatBox } from "@/components/react/shared/ChatBox";

import { Analytics } from "@vercel/analytics/react";
import { SpeedInsights } from "@vercel/speed-insights/react";

export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  showHeader?: boolean;
  hideChatBox?: boolean;
  showFooter?: boolean;
  fullWidth?: boolean;
}

const {
  title,
  description = "Qualisophy - Formación práctica y oportunidades reales.",
  bodyClass = "",
  showHeader = true,
  hideChatBox = false,
  showFooter = true,
  fullWidth = false,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="min-h-screen scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/fonts/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {/* Preload Fonts */}
    <link
      rel="preload"
      href="/fonts/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/WorkSans-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* Google Fonts & Icons */}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300;400;500;600;700&family=Nunito:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  </head>

  <body
    class={`font-primary antialiased min-h-screen flex flex-col ${bodyClass || "bg-white"}`}
  >
    <Analytics framework="astro" client:only="react" />
    <SpeedInsights framework="astro" client:only="react" />

    {showHeader && <Header />}

    <main class="flex-1 w-full">
      {
        fullWidth ? (
          <slot />
        ) : (
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
            <slot />
          </div>
        )
      }
    </main>

    {showFooter && <Footer />}

    <Sidebar client:visible />

    <div id="chatbox-container">
      {!hideChatBox && <ChatBox client:load />}
    </div>
  </body>
</html>

<style is:global>
  body.menu-open #chatbox-container {
    display: none !important;
    pointer-events: none;
  }
  body.menu-open {
    overflow: hidden;
  }
</style>