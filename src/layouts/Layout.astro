---
/**
 * Main layout wrapping all site pages.
 */

import "@/styles/global.css";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Sidebar } from "@/components/react/layout/Sidebar";
import { ChatBox } from "@/components/react/shared/ChatBox";

export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  showHeader?: boolean;
  hideChatBox?: boolean;
  showFooter?: boolean;
  fullWidth?: boolean;
}

const {
  title,
  description = "Qualisophy - Formación práctica y oportunidades reales.",
  bodyClass = "",
  showHeader = true,
  hideChatBox = false,
  showFooter = true,
  fullWidth = false,
} = Astro.props;

---

<!doctype html>
<html lang="es" class="min-h-screen scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/fonts/favicon-white.ico" media="(prefers-color-scheme: dark)">
    <link rel="icon" href="/fonts/favicon-black.ico" media="(prefers-color-scheme: light)">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/50976a705c95b786f0c0e37b8938643c/script.js"></script> 
    {/* Preload Fonts */}
    <link
      rel="preload"
      href="/fonts/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/WorkSans-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* Google Fonts & Icons */}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300;400;500;600;700&family=Nunito:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

  </head>

  <body
    class={`font-primary antialiased min-h-screen flex flex-col ${bodyClass || "bg-white"}`}
  >

    {/* HEADER: Con ID 'site-header' y sticky para que el script del chat lo detecte */}
    <div id="site-header" class="sticky top-0 z-40 w-full bg-white shadow-sm">
        {showHeader && <Header />}
    </div>

    <main class="flex-1 w-full relative z-10">
      {
        fullWidth ? (
          <slot />
        ) : (
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
            <slot />
          </div>
        )
      }
    </main>

    {/* FOOTER: Con ID 'site-footer' para que el chat 'rebote' sobre él */}
    <div id="site-footer" class="relative z-30 bg-white">
        {showFooter && <Footer />}
    </div>

    <Sidebar client:visible />

    <div id="chatbox-container" class="relative z-50">
      {!hideChatBox && <ChatBox client:load />}
    </div>

    {/* SCRIPT PARA DETECTAR FOOTER Y EMPUJAR EL BOTÓN DE COOKIEYES */}
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const checkFooterCollision = () => {
          const footer = document.getElementById("site-footer");
          const cookieBtn = document.querySelector(".cky-btn-revisit-wrapper");
          
          if (footer && cookieBtn) {
            const footerRect = footer.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            
            // Si el footer entra en la zona visible de la pantalla
            if (footerRect.top < windowHeight) {
              // Calculamos cuánto ha subido el footer y se lo sumamos a los 20px base
              const offset = (windowHeight - footerRect.top) + 20;
              cookieBtn.style.setProperty("bottom", `${offset}px`, "important");
            } else {
              // Si el footer no se ve, el botón vuelve a su posición original flotante
              cookieBtn.style.setProperty("bottom", "20px", "important");
            }
          }
        };

        // Escuchamos el evento de scroll y redimensionado de pantalla
        window.addEventListener("scroll", checkFooterCollision, { passive: true });
        window.addEventListener("resize", checkFooterCollision, { passive: true });
      });
    </script>
  </body>
</html>

<style is:global>
  body.menu-open #chatbox-container {
    display: none !important;
    pointer-events: none;
  }
  body.menu-open {
    overflow: hidden;
  }
</style>