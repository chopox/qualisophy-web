---
/**
 * Main layout wrapping all site pages.
 */

import "@/styles/global.css";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Sidebar } from "@/components/react/layout/Sidebar";
import { ChatBox } from "@/components/react/shared/ChatBox";

export interface Props {
  title: string;
  description?: string;
  image?: string; // Propiedad para la imagen de redes sociales
  bodyClass?: string;
  showHeader?: boolean;
  hideChatBox?: boolean;
  showFooter?: boolean;
  fullWidth?: boolean;
}

const {
  title,
  description = "Qualisophy - Formación práctica y oportunidades reales.",
  image = "/assets/logomark-white.jpg",
  bodyClass = "",
  showHeader = true,
  hideChatBox = false,
  showFooter = true,
  fullWidth = false,
} = Astro.props;

// Configuración de URLs absolutas para WhatsApp
const siteUrl = "https://www.qualisophy.com";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl).href;

---

<!doctype html>
<html lang="es" class="min-h-screen scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/fonts/favicon-white.ico" media="(prefers-color-scheme: dark)">
    <link rel="icon" href="/fonts/favicon-black.ico" media="(prefers-color-scheme: light)">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    {/* ETIQUETAS OPEN GRAPH (WHATSAPP, LINKEDIN, FACEBOOK) */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* ETIQUETAS TWITTER CARDS */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/50976a705c95b786f0c0e37b8938643c/script.js"></script> 
    {/* Preload Fonts */}
    <link
      rel="preload"
      href="/fonts/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/WorkSans-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* Google Fonts & Icons */}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300;400;500;600;700&family=Nunito:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

  </head>

  <body
    class={`font-primary antialiased min-h-screen flex flex-col ${bodyClass || "bg-white"}`}
  >

    {/* HEADER: Con ID 'site-header' y sticky para que el script del chat lo detecte */}
    <div id="site-header" class="sticky top-0 z-40 w-full bg-white shadow-sm">
        {showHeader && <Header />}
    </div>

    <main class="flex-1 w-full relative z-10">
      {
        fullWidth ? (
          <slot />
        ) : (
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
            <slot />
          </div>
        )
      }
    </main>

    {/* FOOTER: Con ID 'site-footer' para que el chat 'rebote' sobre él */}
    <div id="site-footer" class="relative z-30 bg-white">
        {showFooter && <Footer />}
    </div>

    <Sidebar client:visible />

    <div id="chatbox-container" class="relative z-50">
      {!hideChatBox && <ChatBox client:load />}
    </div>

    {/* SCRIPT PARA DETECTAR FOOTER Y EMPUJAR EL BOTÓN DE COOKIEYES */}
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const checkFooterCollision = () => {
          const footer = document.getElementById("site-footer");
          const cookieBtn = document.querySelector(".cky-btn-revisit-wrapper");
          const enrollBtn = document.getElementById("floating-enroll-btn");
          
          if (footer && cookieBtn) {
            const footerRect = footer.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            
            // 32px es la altura base, igual que el chat
            let newBottom = 32; 
            const overlap = windowHeight - footerRect.top;
            
            if (overlap > 0) {
              newBottom = overlap + 32;
            }

            // Si el botón de inscripción está presente en pantallas móviles, subimos el de cookies encima
            if (enrollBtn && window.innerWidth < 1024) {
               const enrollBtnHeight = enrollBtn.offsetHeight || 48;
               newBottom += (enrollBtnHeight + 12);
            }
            
            cookieBtn.style.setProperty("bottom", `${newBottom}px`, "important");
            cookieBtn.style.setProperty("left", "16px", "important"); // Lo forzamos a la izquierda por JS
            cookieBtn.style.setProperty("z-index", "999", "important");
          }
        };

        // Como CookieYes carga asíncronamente, vigilamos hasta que aparezca el botón
        const waitForCookieBtn = setInterval(() => {
          const cookieBtn = document.querySelector(".cky-btn-revisit-wrapper");
          if (cookieBtn) {
            // El botón ya existe, calculamos posición inicial y añadimos los listeners
            checkFooterCollision();
            window.addEventListener("scroll", checkFooterCollision, { passive: true });
            window.addEventListener("resize", checkFooterCollision, { passive: true });
            clearInterval(waitForCookieBtn); // Paramos el vigilante
          }
        }, 300);

        // Por seguridad, si a los 10 segundos no ha cargado, paramos el intervalo
        setTimeout(() => clearInterval(waitForCookieBtn), 10000);
      });
    </script>
  </body>
</html>

<style is:global>

  body.menu-open #chatbox-container {
    display: none !important;
  }

  body[style*="overflow: hidden"] #chatbox-container {
    display: none !important;
  }

  body.modal-open #chatbox-container {
    display: none !important;
  }

</style>
