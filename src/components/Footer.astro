---
// src/components/Footer.astro

import logo from "@/assets/qualisophy-white.png";

const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary border-t border-gray-700 relative isolate">
  {/* Fondo con patrón */}
  <div
    class="absolute inset-0 bg-[url('/assets/pattern.svg')] bg-bottom bg-repeat-x bg-cover opacity-20 z-[-1]"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8 relative z-10">
    
    {/* --- SECCIÓN SUPERIOR: LOGO Y CONTACTO --- */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start mb-12">
      
      {/* Bloque Izquierdo: Logo y Eslogan */}
      <div>
        <a href="/" class="block mb-6">
          <img
            src={logo.src}
            alt="Qualisophy Logo"
            class="h-10 w-auto object-contain" 
            width={logo.width}
            height={logo.height}
          />
        </a>
        <p class="text-gray-200 text-base leading-relaxed max-w-md" data-i18n="footer.slogan">
          Formación práctica, personalizada y oportunidades reales
          para el crecimiento profesional.
        </p>
      </div>

      {/* Bloque Derecho: Datos de Contacto */}
      <div class="md:text-right flex flex-col md:items-end justify-center h-full">
        <div class="flex flex-col space-y-4 text-base text-gray-100 font-medium">
          
          <a href="mailto:hello@qualisophy.com" class="hover:text-primary transition-colors flex items-center gap-3 md:flex-row-reverse">
            <span class="material-symbols-outlined text-[22px] text-primary">mail</span> 
            hello@qualisophy.com
          </a>
          
          <a href="tel:+34951768789" class="hover:text-primary transition-colors flex items-center gap-3 md:flex-row-reverse">
            <span class="material-symbols-outlined text-[22px] text-primary">call</span> 
            +34 951 768 789
          </a>

          <a 
            href="https://maps.google.com/?q=Calle+Esteban+Salazar+Chapela+11,+Málaga" 
            target="_blank" 
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors flex items-center gap-3 md:flex-row-reverse"
          >
            <span class="material-symbols-outlined text-[22px] text-primary">location_on</span>
            Calle Esteban Salazar Chapela 11, Málaga
          </a>

        </div>
      </div>
    </div>


    {/* --- SECCIÓN MEDIA: ENLACES REESTRUCTURADOS --- */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-gray-700/50 pt-12">
      
      {/* 1. INCLUSIÓN (URLs Corregidas) */}
      <div>
        <h3 class="text-sm font-semibold text-white tracking-wider uppercase mb-4">
          Inclusión
        </h3>
        <ul class="space-y-3">
          {/* CORREGIDO: Eliminado /learning/ de las rutas */}
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/neurodivergence">Neurodivergencia</a></li>
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/rural-area">Entorno Rural</a></li>
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/migrant-talent">Talento Migrante</a></li>
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/social-impact">Riesgo de Exclusión</a></li>
        </ul>
      </div>

      {/* 2. FORMACIONES (Prioridad Alta) */}
      <div>
        <h3 class="text-sm font-semibold text-white tracking-wider uppercase mb-4">
          Formaciones
        </h3>
        <ul class="space-y-3">
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/learning">Para Particulares</a></li>
          <li><a class="text-sm text-gray-300 hover:text-primary hidden transition-colors" href="/corporate-training">Para Empresas</a></li>
        </ul>
      </div>

      {/* 3. ¿COLABORAMOS? (Nuevo enfoque Partnership) */}
      <div>
        <h3 class="text-sm font-semibold text-white tracking-wider uppercase mb-4">
          ¿Colaboramos?
        </h3>
        <ul class="space-y-3">
          <li>
            <a class="text-sm text-gray-300 hover:text-primary transition-colors flex items-center gap-2" href="/partnership">
              Partnership
              <span class="text-xs bg-primary/20 text-primary px-2 py-0.5 rounded-full border border-primary/30">Empresas</span>
            </a>
          </li>
        </ul>
      </div>

      {/* 4. CONÓCENOS (Incluye Inicio) */}
      <div>
        <h3 class="text-sm font-semibold text-white tracking-wider uppercase mb-4">
          Conócenos
        </h3>
        <ul class="space-y-3">
          {/* NUEVO: Inicio movido aquí */}
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/team">Nuestro Equipo</a></li>
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/blog">Blog & Actualidad</a></li>
          <li><a class="text-sm text-gray-300 hover:text-primary transition-colors" href="/contact">Contacto</a></li>
        </ul>
      </div>


    </div>


    {/* --- BARRA INFERIOR --- */}
    <div class="mt-12 border-t border-gray-200 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      
      {/* Redes Sociales */}
      <div class="flex space-x-6 order-2 md:order-2">
        <a href="https://www.instagram.com/qualisophy/" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white transition-all hover:-translate-y-1" aria-label="Instagram">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.451 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.821-.049.975-.045 1.504-.207 1.857-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.049-3.821-.045-.975-.207-1.504-.344-1.857a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
        </a>
        <a href="https://x.com/qualisophy" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white transition-all hover:-translate-y-1" aria-label="X (Twitter)">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z" /></svg>
        </a>
        <a href="https://www.linkedin.com/company/qualisophy/" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white transition-all hover:-translate-y-1" aria-label="LinkedIn">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
        </a>
      </div>

      <p class="text-base text-gray-200 order-1 md:order-1 text-center md:text-left w-full md:w-auto">
        Qualisophy&#174; - <span data-i18n="footer.rights">Marca registrada</span>
      </p>
    </div>
  </div>

  <script>
    import { getCurrentLanguage, getTranslations } from '@/i18n/ui';

    function updateFooterTranslations() {
      const lang = getCurrentLanguage();
      const translations = getTranslations(lang);
      
      document.querySelectorAll('[data-i18n]').forEach((element) => {
        const key = element.getAttribute('data-i18n') as keyof typeof translations;
        if (key && translations[key]) {
          if (element.children.length === 0) {
            element.textContent = translations[key];
          } else {
            const childNodes = Array.from(element.childNodes);
            childNodes.forEach(node => {
              if (node.nodeType === Node.TEXT_NODE) {
                node.textContent = translations[key];
              }
            });
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', updateFooterTranslations);
    window.addEventListener('languageChanged', updateFooterTranslations);
  </script>
</footer>