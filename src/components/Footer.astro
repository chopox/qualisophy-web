---
// src/components/Footer.astro

// Import the logo image, following the project's pattern
import logo from "@/assets/qualisophy-white.png";

// Get the current year dynamically for the copyright
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary border-t border-gray-700 relative isolate">
  {/* Layer 1: Background Pattern (Forced to the back) */}
  <div
    class="absolute inset-0 bg-[url('/assets/pattern.svg')] bg-bottom bg-repeat-x bg-cover opacity-20 z-[-1]"
    aria-hidden="true"
  >
  </div>

  {/* Layer 2: Content (Forced to the front) */}
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8 relative z-10">
    {
    
    }
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-start">
      {/* Column 1: Logo & Slogan */}
      <div class="col-span-2 md:col-span-2">
        <a href="/" class="flex items-center gap-2">
          <img
            src={logo.src}
            alt="Qualisophy Logo"
            class="h-6 w-auto"
            width={logo.width}
            height={logo.height}
          />
        </a>
        {
          /* You might want to add some 'mt-' here if the slogan feels too close to the logo now */
        }
<p class="text-gray-200 text-sm mt-2" data-i18n="footer.slogan">
          Formación práctica, consultoría personalizada y oportunidades reales
          para el crecimiento profesional.
        </p>
      </div>

      {/* Column 2: Navigation */}
      {
      }
      <div>
<h3 class="text-sm font-semibold text-white tracking-wider uppercase" data-i18n="footer.navigation">
          Navegación
        </h3>
        <ul class="mt-4 space-y-2">
          <li>
<a class="text-base text-gray-200 hover:text-primary" href="/" data-i18n="nav.home">
              Inicio
            </a>
          </li>
          <li>
            <a
             class="text-base text-gray-200 hover:text-primary"
  href="/partnership"
  data-i18n="nav.partnership"
>
              Partnership
            </a>
          </li>
          <li>
            <a
              class="text-base text-gray-200 hover:text-primary"
  href="/contact"
  data-i18n="nav.contact"
>
              Contacto
            </a>
          </li>
        </ul>
      </div>

      {/* Column 3: Contact */}
      {
      }
      <div>
<h3 class="text-sm font-semibold text-white tracking-wider uppercase" data-i18n="footer.contact">
          Contacto
        </h3>
        <ul class="mt-4 space-y-2">
          <li>
            <a
              href="mailto:hello@qualisophy.com"
              class="flex items-center text-gray-300 hover:text-primary transition-colors"
            >
              hello@qualisophy.com
            </a>
          </li>
          <li>
            <a
              href="tel:+34951768789"
              class="flex items-center text-gray-300 hover:text-primary transition-colors"
            >
              +34 951 768 789
            </a>
          </li>
          <li>
            <a
              href="https://maps.app.goo.gl/VStbnoiDd58fEe8m9"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center text-gray-300 hover:text-primary transition-colors"
            >
              Calle Esteban Salazar Chapela 11, Málaga
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom Bar: Copyright & Socials */}
    <div
      class="mt-8 border-t border-gray-200 pt-8 md:flex md:items-center md:justify-between"
    >
      <div class="flex space-x-6 md:order-2">
        <a
          href="https://www.youtube.com/watch?v=dQw4w9WgXcQ&list=RDdQw4w9WgXcQ&start_radio=1"
          target="_blank"
          class="text-gray-300 hover:text-white transition-all duration-200 hover:-translate-y-1"
        >
          <span class="sr-only">Facebook</span>
          <svg
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/watch?v=dQw4w9WgXcQ&list=RDdQw4w9WgXcQ&start_radio=1"
          target="_blank"
          class="text-gray-300 hover:text-white transition-all duration-200 hover:-translate-y-1"
        >
          <span class="sr-only">Twitter</span>
          <svg
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.71v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/watch?v=dQw4w9WgXcQ&list=RDdQw4w9WgXcQ&start_radio=1"
          target="_blank"
          class="text-gray-300 hover:text-white transition-all duration-200 hover:-translate-y-1"
        >
          <span class="sr-only">LinkedIn</span>
          <svg
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>

      <p class="mt-8 text-base text-gray-200 md:mt-0 md:order-1">
  © {currentYear} Qualisophy. <span data-i18n="footer.rights">Todos los derechos reservados.</span>
</p>
    </div>
  </div>
  <script>
  import { getCurrentLanguage, getTranslations } from '@/i18n/ui';

  function updateFooterTranslations() {
    const lang = getCurrentLanguage();
    const translations = getTranslations(lang);
    
    // Update all elements with data-i18n attribute
    document.querySelectorAll('[data-i18n]').forEach((element) => {
      const key = element.getAttribute('data-i18n') as keyof typeof translations;
      if (key && translations[key]) {
        // Check if element has child nodes that aren't just text
        if (element.children.length === 0) {
          // Simple text element
          element.textContent = translations[key];
        } else {
          // Element has children, only update text nodes
          const childNodes = Array.from(element.childNodes);
          childNodes.forEach(node => {
            if (node.nodeType === Node.TEXT_NODE) {
              node.textContent = translations[key];
            }
          });
        }
      }
    });
  }

  // Update translations on load
  document.addEventListener('DOMContentLoaded', updateFooterTranslations);

  // Update translations when language changes
  window.addEventListener('languageChanged', updateFooterTranslations);
</script>

</footer>
