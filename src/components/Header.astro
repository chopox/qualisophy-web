---
import { Image } from "astro:assets";
import logoText from "@/assets/logo-q.png";
import logoIcon from "@/assets/logo-q-2.png";
import Menu from "@lucide/astro/icons/menu";
import { LanguageSelector } from "@/components/react/shared/LanguageSelector";

const currentPath = Astro.url.pathname;

// Lógica para marcar activo el menú
const isHome = currentPath === "/";
const isContact = currentPath === "/contact";
const isPartnership = currentPath === "/partnership";

// Grupo Programas
const isNeuro = currentPath === "/neurodivergence";
const isMigrant = currentPath === "/migrant-talent";
const isSocial = currentPath === "/social-impact";
const isProgramsGroup = isNeuro || isMigrant || isSocial;

// Grupo Cursos
const isReskilling = currentPath === "/reskilling";
const isCorporate = currentPath.includes("/corporate-training");
const isCoursesGroup = isReskilling || isCorporate;

// Clases comunes para los items del menú desplegable (interno)
const dropdownItemClass = "block px-4 py-2 rounded-lg transition-all duration-200 text-sm";
const dropdownActiveItemClass = "text-primary bg-blue-50 font-medium"; 
const dropdownInactiveItemClass = "text-gray-700 hover:text-primary hover:bg-gray-50";

// --- NUEVAS CLASES PARA EL HEADER (Full Height + Radial Gradient Glow) ---

// Base: Ocupa toda la altura, centrado verticalmente.
const navItemBaseClass = "h-full px-5 lg:px-6 flex items-center transition-all duration-300 font-medium text-[15px] relative z-10";

// Activo: Degradado RADIAL desde el centro hacia todos los bordes.
// bg-[radial-gradient(...)]: Crea un brillo elíptico desde el centro.
// from-blue-100/60: El centro es azul suave con 60% de opacidad.
// to-transparent: Se desvanece completamente hacia los extremos.
const navItemActiveClass = "text-primary font-bold bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-100/60 to-transparent";

// Inactivo: Hover sutil estándar
const navItemInactiveClass = "text-secondary hover:text-primary hover:bg-gray-50/50";

---

<header class="sticky top-0 z-50 bg-white text-secondary shadow-sm border-b border-gray-100 transition-all duration-300 h-20">
  <nav class="container mx-auto px-6 flex items-center justify-between h-full">

    {/* --- LOGOS --- */}
    <a href="/" class="block shrink-0 h-full flex items-center">
      {/* 1. Logo Móvil (Solo Icono) */}
      <div class="md:hidden flex items-center">
        <Image
          loading="eager"
          src={logoIcon}
          alt="Qualisophy Logo"
          width={60}
          height={60}
          format="webp"
          class="w-10 h-auto"
        />
      </div>

      {/* 2. Logo Escritorio (Texto/Completo) */}
      <div class="hidden md:flex items-center">
        <Image
          loading="eager"
          src={logoText}
          alt="Qualisophy Logo"
          width={240}
          height={70}
          format="webp"
          class="w-48 lg:w-56 h-auto object-contain"
        />
      </div>
    </a>

    {/* --- DESKTOP MENU --- */}
    <ul class="hidden lg:flex items-center h-full gap-1">

      {/* Inicio */}
      <li class="h-full relative">
        <a
          href="/"
          class={`${navItemBaseClass} ${isHome ? navItemActiveClass : navItemInactiveClass}`}
          data-i18n="nav.home">Inicio</a
        >
      </li>

      {/* DROPDOWN 1: Programas Formativos */}
      <li class="relative group h-full">
        <div class="h-full">
            <button
            class={`focus:outline-none cursor-pointer ${navItemBaseClass}
                ${isProgramsGroup ? navItemActiveClass : navItemInactiveClass}`}
            >
            <span class="mr-1">Programas Formativos</span>
            <span class="transform transition-transform duration-300 group-hover:rotate-180 text-[10px]">▼</span>
            </button>
        </div>

        {/* Menú Desplegable */}
        <div class="absolute top-full left-0 w-60 bg-white rounded-b-xl rounded-tr-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 p-2 z-50">
          <div class="flex flex-col gap-1">
            <a href="/neurodivergence" class={`${dropdownItemClass} ${isNeuro ? dropdownActiveItemClass : dropdownInactiveItemClass}`}>
              Neurodivergencia
            </a>
            <a href="/migrant-talent" class={`${dropdownItemClass} ${isMigrant ? dropdownActiveItemClass : dropdownInactiveItemClass}`}>
              Talento Migrante
            </a>
            <a href="/social-impact" class={`${dropdownItemClass} ${isSocial ? dropdownActiveItemClass : dropdownInactiveItemClass}`}>
              Riesgo de Exclusión
            </a>
          </div>
        </div>
      </li>

      {/* DROPDOWN 2: Nuestras Formaciones */}
      <li class="relative group h-full">
         <div class="h-full">
            <button
            class={`focus:outline-none cursor-pointer ${navItemBaseClass}
                ${isCoursesGroup ? navItemActiveClass : navItemInactiveClass}`}
            >
            <span class="mr-1">Nuestras Formaciones</span>
            <span class="transform transition-transform duration-300 group-hover:rotate-180 text-[10px]">▼</span>
            </button>
         </div>

        {/* Menú Desplegable */}
        <div class="absolute top-full left-0 w-60 bg-white rounded-b-xl rounded-tr-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 p-2 z-50">
          <div class="flex flex-col gap-1">
            <a href="/reskilling" class={`${dropdownItemClass} ${isReskilling ? dropdownActiveItemClass : dropdownInactiveItemClass}`}>
              Reciclaje Laboral
            </a>
            <a href="/corporate-training" class={`${dropdownItemClass} ${isCorporate ? dropdownActiveItemClass : dropdownInactiveItemClass}`}>
              Formación Empresas
            </a>
          </div>
        </div>
      </li>

      {/* Partnership */}
      <li class="h-full relative">
        <a
          href="/partnership"
          class={`${navItemBaseClass} ${isPartnership ? navItemActiveClass : navItemInactiveClass}`}
          data-i18n="nav.partnership">Partnership</a
        >
      </li>

      {/* Contacto */}
      <li class="h-full relative">
        <a
          href="/contact"
          class={`${navItemBaseClass} ${isContact ? navItemActiveClass : navItemInactiveClass}`}
          data-i18n="nav.contact">Contacto</a
        >
      </li>

      {/* Selector de Idioma - Separado visualmente */}
      <li class="h-full flex items-center ml-4 pl-4 border-l border-gray-200">
        <div class="text-secondary hover:text-primary font-medium">
            <LanguageSelector client:load />
        </div>
      </li>
    </ul>

    {/* Hamburger Button (Mobile) */}
    <button
      data-sidebar-toggle
      class="lg:hidden text-secondary hover:text-primary transition-colors p-2"
      aria-label="Toggle mobile menu"
    >
      <Menu class="w-8 h-8" />
    </button>
  </nav>

  {/* --- SIDEBAR MÓVIL (Sin cambios) --- */}
  <aside
    id="mobile-sidebar"
    class="fixed top-0 right-0 h-full w-[85%] max-w-sm bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out z-[10000] flex flex-col overflow-y-auto"
  >
    <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50 h-20 shrink-0">
      <span class="font-bold text-xl text-secondary">Menú</span>
      <button
        id="close-sidebar"
        class="text-gray-400 hover:text-primary transition-colors p-2"
        aria-label="Close menu">
        <span class="material-symbols-outlined text-3xl">close</span>
      </button>
    </div>

    <div class="p-6 flex flex-col space-y-1 pb-32">
        <a href="/" class={`py-3 px-4 rounded-xl hover:bg-gray-50 ${isHome ? "text-primary font-bold bg-blue-50" : "text-secondary font-medium"}`}>
            Inicio
        </a>

        <div class="pt-6 pb-2 px-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Programas Formativos</div>
        <a href="/neurodivergence" class={`block py-3 px-4 rounded-xl pl-6 border-l-2 border-transparent hover:border-primary/20 hover:bg-gray-50 ${isNeuro ? "text-primary font-bold bg-blue-50 border-primary" : "text-gray-600 hover:text-primary"}`}>Neurodivergencia</a>
        <a href="/migrant-talent" class={`block py-3 px-4 rounded-xl pl-6 border-l-2 border-transparent hover:border-primary/20 hover:bg-gray-50 ${isMigrant ? "text-primary font-bold bg-blue-50 border-primary" : "text-gray-600 hover:text-primary"}`}>Talento Migrante</a>
        <a href="/social-impact" class={`block py-3 px-4 rounded-xl pl-6 border-l-2 border-transparent hover:border-primary/20 hover:bg-gray-50 ${isSocial ? "text-primary font-bold bg-blue-50 border-primary" : "text-gray-600 hover:text-primary"}`}>Riesgo de Exclusión</a>

        <div class="pt-6 pb-2 px-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Nuestras Formaciones</div>
        <a href="/reskilling" class={`block py-3 px-4 rounded-xl pl-6 border-l-2 border-transparent hover:border-primary/20 hover:bg-gray-50 ${isReskilling ? "text-primary font-bold bg-blue-50 border-primary" : "text-gray-600 hover:text-primary"}`}>Reciclaje Laboral</a>
        <a href="/corporate-training" class={`block py-3 px-4 rounded-xl pl-6 border-l-2 border-transparent hover:border-primary/20 hover:bg-gray-50 ${isCorporate ? "text-primary font-bold bg-blue-50 border-primary" : "text-gray-600 hover:text-primary"}`}>Formación Empresas</a>

        <div class="my-4 border-t border-gray-100"></div>

        <a href="/partnership" class={`py-3 px-4 rounded-xl hover:bg-gray-50 ${isPartnership ? "text-primary font-bold bg-blue-50" : "text-secondary font-medium"}`}>
            Partnership
        </a>
        <a href="/contact" class={`py-3 px-4 rounded-xl hover:bg-gray-50 ${isContact ? "text-primary font-bold bg-blue-50" : "text-secondary font-medium"}`}>
            Contacto
        </a>

        <div class="pt-6 mt-2 px-4">
             <div class="text-secondary font-medium p-2 bg-gray-50 rounded-lg inline-block w-full text-center">
                <LanguageSelector client:load />
             </div>
        </div>
    </div>
  </aside>

  <div
    id="sidebar-overlay"
    class="hidden fixed inset-0 bg-secondary/20 z-[9998] backdrop-blur-sm transition-opacity duration-300 ease-in-out"
  >
  </div>

  <style is:global>
    body.menu-open iframe,
    body.menu-open .intercom-lightweight-app,
    body.menu-open #hubspot-messages-iframe-container,
    body.menu-open div[class*="chat"] {
      display: none !important;
      visibility: hidden !important;
      z-index: -1 !important;
    }
  </style>

  <script>
    import { getCurrentLanguage, getTranslations } from "@/i18n/ui";

    function updateTranslations() {
      const lang = getCurrentLanguage();
      const translations = getTranslations(lang);
      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const key = element.getAttribute("data-i18n") as keyof typeof translations;
        if (key && translations[key]) {
          element.textContent = translations[key];
        }
      });
    }

    document.addEventListener("DOMContentLoaded", updateTranslations);
    window.addEventListener("languageChanged", updateTranslations);
  </script>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const toggleButton = document.querySelector("[data-sidebar-toggle]");
      const sidebar = document.querySelector("#mobile-sidebar");
      const overlay = document.querySelector("#sidebar-overlay");
      const closeButton = document.querySelector("#close-sidebar");

      const openSidebar = () => {
        sidebar.classList.remove("translate-x-full");
        overlay.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");
        document.body.classList.add("menu-open");
      };

      const closeSidebar = () => {
        sidebar.classList.add("translate-x-full");
        overlay.classList.add("hidden");
        document.body.classList.remove("overflow-hidden");
        document.body.classList.remove("menu-open");
      };

      toggleButton?.addEventListener("click", openSidebar);
      closeButton?.addEventListener("click", closeSidebar);
      overlay?.addEventListener("click", closeSidebar);
    });
  </script>
</header>